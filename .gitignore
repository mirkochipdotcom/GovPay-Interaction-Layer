.env
.env.*
!.env.*.example
.iam-proxy.env
!.iam-proxy.env.example
*.log
*.pid
# File generati a runtime dal master container (env iam-proxy, ecc.)
runtime/
.claude/
docker-compose.override.yml

# SSL directory - exclude all except README
ssl/*
!ssl/README.md

# Certificate directory - exclude all except README  
certificate/*
!certificate/README.md

# Debug tool root: ignora tutto tranne README esplicativo (non tracciamo index.php)
debug/*
!debug/README.md

# Ignore composer vendor directory
vendor/

# Logo ente personalizzato (non versionare)
img/stemma_ente.png

# Favicon personalizzate (non versionare)
img/favicon.ico
img/favicon.png

# iam-proxy-italia (SATOSA): progetto upstream baked nell'immagine Docker, non serve in repo
# La directory locale è mantenuta solo come reference (per sviluppo/debug locale)
/iam-proxy/iam-proxy-italia-project/*
!/iam-proxy/iam-proxy-italia-project/.gitkeep
metadata/agid/*
!metadata/agid/.gitkeep
metadata/cieoidc/*
!metadata/cieoidc/.gitkeep
!metadata/cieoidc/README.md
# CIE OIDC keys: generate once per deployment, never commit (contain private keys)
metadata/cieoidc-keys/*
!metadata/cieoidc-keys/.gitkeep

# Backup metadata (generato da metadata-builder backup)
backup/

# Piani e note locali
plans/

# Local directory for runtime data (outside repository)
.local/
/iam-proxy/nginx/html/static/*
!/iam-proxy/nginx/html/static/.gitkeep

