{% extends 'base.html.twig' %}

{% block title %}Home - GovPay{% endblock %}

{% block content %}
  <h2 class="it-title">Benvenuto in GovPay Interaction Layer (GIL)</h2>
  <p>Questo applicativo serve a interagire con un istanza PagoPA gestita con un nodo <a href="https://govpay.readthedocs.io/">GovPay</a>.</p>
  <div class="mt-3">
    <a href="/guida" class="btn btn-primary">
      <i class="fas fa-book-open me-2"></i>Apri la guida rapida
    </a>
  </div>

  {# Widget stato container Portainer #}
  <div class="mt-4" id="portainer-widget">
    <h4 class="mb-2"><i class="fas fa-server me-2"></i>Stato Container</h4>
    <div id="portainer-content">
      <div class="d-flex align-items-center text-muted">
        <div class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></div>
        <span>Caricamento stato container...</span>
      </div>
    </div>
  </div>

  <script>
  (function () {
    const container = document.getElementById('portainer-content');

    function stateIcon(state) {
      if (state === 'running')  return '<span class="badge bg-success me-1">running</span>';
      if (state === 'exited')   return '<span class="badge bg-secondary me-1">stopped</span>';
      if (state === 'paused')   return '<span class="badge bg-warning text-dark me-1">paused</span>';
      return '<span class="badge bg-light text-dark me-1">' + state + '</span>';
    }

    fetch('/api/portainer/status')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) {
          var msg = data.message || data.error;
          if (data.error === 'not_configured') {
            container.innerHTML =
              '<div class="alert alert-warning mb-0">' +
              '<i class="fas fa-triangle-exclamation me-2"></i>' +
              'Impossibile contattare Portainer (' + (data.url || 'non configurato') + ') — ' +
              'configura <code>PORTAINER_URL</code> e <code>PORTAINER_API_TOKEN</code> nelle variabili d\'ambiente.' +
              '</div>';
          } else {
            container.innerHTML =
              '<div class="alert alert-danger mb-0">' +
              '<i class="fas fa-circle-xmark me-2"></i>' +
              '<strong>Errore Portainer:</strong> ' + msg +
              '</div>';
          }
          return;
        }

        var rows = '';
        var list = data.containers || [];
        if (list.length === 0) {
          rows = '<tr><td colspan="3" class="text-muted">Nessun container trovato</td></tr>';
        } else {
          list.forEach(function(c) {
            rows +=
              '<tr>' +
              '<td class="font-monospace small">' + stateIcon(c.state) + c.name + '</td>' +
              '<td class="small text-muted">' + c.image + '</td>' +
              '<td class="small">' + c.status + '</td>' +
              '</tr>';
          });
        }

        container.innerHTML =
          '<p class="text-muted small mb-2">Endpoint: <strong>' + data.endpoint + '</strong></p>' +
          '<div class="table-responsive">' +
          '<table class="table table-sm table-hover mb-0">' +
          '<thead><tr><th>Container</th><th>Immagine</th><th>Stato</th></tr></thead>' +
          '<tbody>' + rows + '</tbody>' +
          '</table>' +
          '</div>';
      })
      .catch(function(err) {
        container.innerHTML =
          '<div class="alert alert-danger mb-0">' +
          '<i class="fas fa-circle-xmark me-2"></i>' +
          'Errore nel recupero dello stato container: ' + err.message +
          '</div>';
      });
  })();
  </script>
{% endblock %}
