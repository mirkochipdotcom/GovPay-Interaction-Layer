{% extends 'setup/layout.html.twig' %}
{% from 'setup/_step_header.html.twig' import step_header %}
{% block title %}Step 1 — Dati Ente{% endblock %}

{% block content %}
{{ step_header(step, total_steps) }}

<div class="card card-wizard p-4">
  <h2 class="h4 mb-1"><i class="fa fa-building me-2 text-primary"></i>Dati dell'Ente</h2>
  <p class="text-muted mb-4">Inserisci le informazioni identificative dell'ente.</p>

  {% if errors %}
    <div class="alert alert-danger">
      <ul class="mb-0">{% for e in errors %}<li>{{ e }}</li>{% endfor %}</ul>
    </div>
  {% endif %}

  <form method="post" action="/setup/step/1" enctype="multipart/form-data">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <input type="hidden" name="mode" value="{{ mode }}">

    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Nome dell'Ente <span class="text-danger">*</span></label>
        <input type="text" class="form-control {% if errors.entity_name is defined %}is-invalid{% endif %}"
               name="entity_name" value="{{ data.entity_name|default('') }}" required placeholder="es. Comune di Roma">
        {% if errors.entity_name is defined %}<div class="invalid-feedback">{{ errors.entity_name }}</div>{% endif %}
      </div>
      <div class="col-md-6">
        <label class="form-label">Codice IPA</label>
        <input type="text" class="form-control" name="entity_ipa_code"
               value="{{ data.entity_ipa_code|default('') }}" placeholder="es. c_h501">
        <div class="field-help">Codice IPA dell'ente (es. c_h501 per Roma)</div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Provincia / Suffisso</label>
        <input type="text" class="form-control" name="entity_suffix"
               value="{{ data.entity_suffix|default('') }}" placeholder="es. Provincia di Roma">
      </div>
      <div class="col-md-6">
        <label class="form-label">Regione</label>
        <input type="text" class="form-control" name="entity_government"
               value="{{ data.entity_government|default('') }}" placeholder="es. Regione Lazio">
      </div>
      <div class="col-md-6">
        <label class="form-label">ID Dominio <span class="text-danger">*</span></label>
        <input type="text" class="form-control {% if errors.id_dominio is defined %}is-invalid{% endif %}"
               name="id_dominio" value="{{ data.id_dominio|default('') }}" placeholder="es. 00123456789" required>
        <div class="field-help">Partita IVA o codice fiscale dell'ente (usato su GovPay)</div>
        {% if errors.id_dominio is defined %}<div class="invalid-feedback">{{ errors.id_dominio }}</div>{% endif %}
      </div>
      <div class="col-md-6">
        <label class="form-label">ID A2A</label>
        <input type="text" class="form-control" name="id_a2a"
               value="{{ data.id_a2a|default('') }}" placeholder="es. COMUNE_ROMA">
        <div class="field-help">Identificativo applicazione A2A su GovPay</div>
      </div>
      <div class="col-12">
        <label class="form-label">URL sito istituzionale</label>
        <input type="url" class="form-control" name="entity_url"
               value="{{ data.entity_url|default('') }}" placeholder="https://www.comune.roma.it">
      </div>
    </div>

    <hr class="my-4">
    <h6 class="fw-semibold mb-1"><i class="fa fa-image me-2 text-secondary"></i>Logo / Stemma ente <span class="badge bg-light text-muted fw-normal">opzionale</span></h6>
    <p class="text-muted small mb-3">Carica il logo o stemma dell'ente che verrà mostrato nell'intestazione. Se non caricato ora, sarà possibile farlo in seguito dalla sezione Impostazioni → Frontoffice.</p>
    <div class="row g-3 align-items-center">
      <div class="col-auto">
        <img id="logo-preview" src="" alt="" style="max-height:60px;max-width:140px;display:none;border:1px solid #dee2e6;border-radius:4px;padding:4px;">
      </div>
      <div class="col">
        {% if errors.logo_file is defined %}
          <div class="alert alert-danger py-2 mb-2 small">{{ errors.logo_file }}</div>
        {% endif %}
        <input type="file" class="form-control" name="logo_file" id="logo-file"
               accept=".png,.jpg,.jpeg,.svg" onchange="previewLogo(this)">
        <div class="form-text">PNG, JPG o SVG · dimensione consigliata: 200×60 px</div>
      </div>
    </div>

    <div class="d-flex justify-content-between mt-4">
      <a href="/setup" class="btn btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Indietro</a>
      <button type="submit" class="btn btn-primary">Avanti <i class="fa fa-arrow-right ms-1"></i></button>
    </div>
  </form>
</div>
{% endblock %}

{% block scripts %}
<script>
function previewLogo(input) {
  const preview = document.getElementById('logo-preview');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { preview.src = e.target.result; preview.style.display = ''; };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>
{% endblock %}
