{% extends 'setup/layout.html.twig' %}
{% from 'setup/_step_header.html.twig' import step_header %}
{% block title %}Step 5 — Riepilogo{% endblock %}

{% block content %}
{{ step_header(step, total_steps) }}

<div class="card card-wizard p-4">
  <h2 class="h4 mb-1"><i class="fa fa-clipboard-check me-2 text-primary"></i>Riepilogo configurazione</h2>
  <p class="text-muted mb-4">Verifica i dati inseriti prima di avviare l'installazione.</p>

  {% set step1 = all_data.step1|default({}) %}
  {% set step2 = all_data.step2|default({}) %}
  {% set step3 = all_data.step3|default({}) %}

  <div class="row g-3">
    <div class="col-md-6">
      <div class="card border-0 bg-light p-3 h-100">
        <h6 class="fw-semibold"><i class="fa fa-building me-2 text-primary"></i>Ente</h6>
        <dl class="mb-0 small">
          <dt>Nome</dt><dd>{{ step1.entity_name|default('—') }}</dd>
          <dt>Codice IPA</dt><dd>{{ step1.entity_ipa_code|default('—') }}</dd>
          <dt>ID Dominio</dt><dd>{{ step1.id_dominio|default('—') }}</dd>
          <dt>ID A2A</dt><dd>{{ step1.id_a2a|default('—') }}</dd>
        </dl>
        <a href="/setup/step/1" class="btn btn-sm btn-outline-secondary mt-2">Modifica</a>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 bg-light p-3 h-100">
        <h6 class="fw-semibold"><i class="fa fa-user-shield me-2 text-primary"></i>Accesso e URL</h6>
        <dl class="mb-0 small">
          <dt>Superadmin</dt><dd>{{ step2.admin_email|default('—') }}</dd>
          <dt>URL Backoffice</dt><dd>{{ step2.backoffice_url|default('—') }}</dd>
          <dt>URL Frontoffice</dt><dd>{{ step2.frontoffice_url|default('—') }}</dd>
        </dl>
        <a href="/setup/step/2" class="btn btn-sm btn-outline-secondary mt-2">Modifica</a>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 bg-light p-3 h-100">
        <h6 class="fw-semibold"><i class="fa fa-plug me-2 text-primary"></i>GovPay</h6>
        <dl class="mb-0 small">
          <dt>URL Backoffice</dt><dd class="text-truncate">{{ step3.govpay_backoffice_url|default('—') }}</dd>
          <dt>Autenticazione</dt><dd>{{ step3.authentication_govpay|default('basic') }}</dd>
        </dl>
        <a href="/setup/step/3" class="btn btn-sm btn-outline-secondary mt-2">Modifica</a>
      </div>
    </div>
  </div>

  <div class="alert alert-info mt-4">
    <i class="fa fa-info-circle me-2"></i>
    Dopo l'installazione il frontoffice partirà <strong>senza autenticazione SPID/CIE</strong>.
    La configurazione del Login Proxy è disponibile nel pannello <strong>Impostazioni → Login Proxy</strong>.
  </div>

  <form method="post" action="/setup/complete">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <div class="d-flex justify-content-between mt-4">
      <a href="/setup/step/4" class="btn btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Indietro</a>
      <button type="submit" class="btn btn-success btn-lg">
        <i class="fa fa-rocket me-2"></i>Avvia installazione
      </button>
    </div>
  </form>
</div>
{% endblock %}
