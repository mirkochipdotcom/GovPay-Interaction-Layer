{% extends 'setup/layout.html.twig' %}
{% block title %}Anteprima restore{% endblock %}

{% block content %}
<div class="card card-wizard p-4">
  <h2 class="h4 mb-1"><i class="fa fa-eye me-2 text-success"></i>Anteprima backup da ripristinare</h2>
  <p class="text-muted mb-4">Verifica il contenuto del backup prima di procedere.</p>

  <dl class="row">
    <dt class="col-md-4">File</dt>
    <dd class="col-md-8"><code>{{ filename }}</code></dd>
    {% if manifest.created_at is defined %}
    <dt class="col-md-4">Data backup</dt>
    <dd class="col-md-8">{{ manifest.created_at }}</dd>
    {% endif %}
    {% if manifest.entity_name is defined and manifest.entity_name %}
    <dt class="col-md-4">Ente</dt>
    <dd class="col-md-8">{{ manifest.entity_name }}</dd>
    {% endif %}
    {% if manifest.components is defined %}
    <dt class="col-md-4">Componenti</dt>
    <dd class="col-md-8">
      {% for c in manifest.components %}
        <span class="badge bg-success me-1">{{ c }}</span>
      {% endfor %}
    </dd>
    {% endif %}
  </dl>

  <div class="alert alert-warning">
    <i class="fa fa-exclamation-triangle me-2"></i>
    Il ripristino <strong>sovrascriverà</strong> tutta la configurazione e il database correnti.
    Questa operazione non è reversibile.
  </div>

  <form method="post" action="/setup/restore/confirm">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <div class="d-flex justify-content-between mt-3">
      <a href="/setup/restore" class="btn btn-outline-secondary"><i class="fa fa-arrow-left me-1"></i>Annulla</a>
      <button type="submit" class="btn btn-danger">
        <i class="fa fa-undo me-2"></i>Conferma ripristino
      </button>
    </div>
  </form>
</div>
{% endblock %}
