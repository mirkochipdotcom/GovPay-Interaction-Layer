{% extends 'setup/layout.html.twig' %}
{% block title %}Benvenuto — Setup GIL{% endblock %}

{% block content %}
<div class="card card-wizard p-4">
  <div class="text-center mb-4">
    <i class="fa fa-rocket fa-3x text-primary mb-3"></i>
    <h1 class="h3">Benvenuto in GovPay Interaction Layer</h1>
    <p class="text-muted">Il sistema non è ancora configurato. Scegli come procedere.</p>
  </div>

  {% if mode == 'upgrade' %}
  <div class="alert alert-info">
    <i class="fa fa-info-circle me-2"></i>
    <strong>Migrazione rilevata.</strong> Sono state trovate variabili di configurazione legacy (<code>.env</code>).
    I form verranno pre-compilati automaticamente con i valori esistenti.
  </div>
  {% endif %}

  <div class="row g-3 mt-2">
    <div class="col-md-6">
      <a href="/setup/step/1?mode={{ mode }}" class="text-decoration-none">
        <div class="card h-100 border-primary p-4 text-center">
          <i class="fa fa-plus-circle fa-2x text-primary mb-3"></i>
          <h5>Nuova configurazione</h5>
          <p class="text-muted small mb-0">Configura il sistema da zero seguendo la procedura guidata.</p>
        </div>
      </a>
    </div>
    <div class="col-md-6">
      <a href="/setup/restore" class="text-decoration-none">
        <div class="card h-100 border-success p-4 text-center">
          <i class="fa fa-upload fa-2x text-success mb-3"></i>
          <h5>Ripristina da backup</h5>
          <p class="text-muted small mb-0">Hai un file di backup? Caricalo per ripristinare una configurazione precedente.</p>
        </div>
      </a>
    </div>
  </div>
</div>
{% endblock %}
