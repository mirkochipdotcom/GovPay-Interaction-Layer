{% extends 'setup/layout.html.twig' %}
{% block title %}Setup completato{% endblock %}

{% block content %}
<div class="card card-wizard p-5 text-center">
  <i class="fa fa-check-circle fa-4x text-success mb-4"></i>
  <h2 class="h3 mb-3">Configurazione completata!</h2>
  <p class="text-muted mb-4">
    Il sistema è stato configurato correttamente.<br>
    I container si stanno riavviando — attendi qualche secondo prima di accedere.
  </p>
  <a href="/login" class="btn btn-primary btn-lg mx-auto" style="max-width: 240px;">
    <i class="fa fa-sign-in-alt me-2"></i>Vai al login
  </a>
</div>
{% endblock %}
