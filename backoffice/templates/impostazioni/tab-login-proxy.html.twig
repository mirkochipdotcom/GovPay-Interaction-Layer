<div id="lp-wrap">
  {# ─── Status bar ─────────────────────────────────────────────────────────── #}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2 py-3">
      <div class="d-flex align-items-center gap-2">
        <span id="lp-status-dot" class="master-status-dot bg-secondary"></span>
        <strong>Login Proxy (IAM Proxy)</strong>
        <span id="lp-status-text" class="text-muted small">Stato sconosciuto</span>
      </div>
      {% if is_superadmin %}
      <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-sm btn-success" onclick="impAction('/impostazioni/login-proxy/avvia', this, 'Avvio…')">
          <i class="fas fa-play me-1"></i>Avvia
        </button>
        <button class="btn btn-sm btn-danger" onclick="impAction('/impostazioni/login-proxy/arresta', this, 'Arresto…')">
          <i class="fas fa-stop me-1"></i>Arresta
        </button>
        <button class="btn btn-sm btn-warning" onclick="impAction('/impostazioni/login-proxy/riavvia', this, 'Riavvio…')">
          <i class="fas fa-sync-alt me-1"></i>Riavvia
        </button>
        <button class="btn btn-sm btn-outline-secondary" onclick="lpPreviewRigenera(this)">
          <i class="fas fa-redo me-1"></i>Rigenera SP Metadata
        </button>
      </div>
      {% endif %}
    </div>
  </div>

  <form id="form-login-proxy" onsubmit="return false;">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    {# ─── Accordion ───────────────────────────────────────────────────────── #}
    <div class="accordion mb-3" id="acc-lp">

      {# ─── Generale ─────────────────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#lp-generale">
            <i class="fas fa-globe me-2 text-primary"></i>Generale
          </button>
        </h2>
        <div id="lp-generale" class="accordion-collapse collapse show" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label">URL pubblico del proxy <span class="text-danger">*</span></label>
                <input type="url" class="form-control" name="public_base_url" id="lp-public-url"
                  value="{{ iam_proxy.public_base_url|default('') }}" placeholder="https://login.comune.example.it"
                  {{ not is_superadmin ? 'readonly' : '' }}>
                <div class="form-text">URL radice del proxy IAM (es. <code>https://login.comune.example.it</code>). Usato per derivare automaticamente i vari endpoint.</div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Hostname interno</label>
                <input type="text" class="form-control font-monospace" name="hostname" id="lp-hostname"
                  value="{{ iam_proxy.hostname|default('') }}" placeholder="login.comune.example.it"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-3">
                <label class="form-label">Porta HTTP</label>
                <input type="number" class="form-control" name="http_port"
                  value="{{ iam_proxy.http_port|default('8080') }}" min="1" max="65535"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-5">
                <label class="form-label">SATOSA base path</label>
                <input type="text" class="form-control font-monospace" name="satosa_base"
                  value="{{ iam_proxy.satosa_base|default('/saml2/idp') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-12">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="debug" id="lp-debug" value="true"
                    {{ iam_proxy.debug|default('false') == 'true' ? 'checked' : '' }}
                    {{ not is_superadmin ? 'disabled' : '' }}>
                  <label class="form-check-label" for="lp-debug">Modalità debug (verbose logging)</label>
                </div>
              </div>
            </div>

            <hr class="my-3">
            <p class="text-muted small mb-2">Metodi di autenticazione abilitati:</p>
            <div class="d-flex gap-4 flex-wrap">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_spid" id="en-spid" value="true"
                  {{ iam_proxy.enable_spid|default('false') == 'true' ? 'checked' : '' }}
                  {{ not is_superadmin ? 'disabled' : '' }}>
                <label class="form-check-label" for="en-spid">SPID</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_cie_oidc" id="en-cie" value="true"
                  {{ iam_proxy.enable_cie_oidc|default('false') == 'true' ? 'checked' : '' }}
                  {{ not is_superadmin ? 'disabled' : '' }}>
                <label class="form-check-label" for="en-cie">CIE OIDC</label>
              </div>
            </div>
            {# Mantieni i valori nascosti per IT Wallet e OIDCOP (non ancora supportati nell'UI) #}
            <input type="hidden" name="enable_it_wallet" value="{{ iam_proxy.enable_it_wallet|default('false') }}">
            <input type="hidden" name="enable_oidcop" value="{{ iam_proxy.enable_oidcop|default('false') }}">
          </div>
        </div>
      </div>

      {# ─── SPID / SAML2 ─────────────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-spid">
            <i class="fas fa-id-card me-2 text-success"></i>SPID / SAML2
          </button>
        </h2>
        <div id="lp-spid" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">

            {# URL metadata SATOSA (calcolati da URL pubblico) #}
            <h6 class="text-muted text-uppercase small fw-semibold mb-2">
              <i class="fas fa-link me-1"></i>URL metadata SATOSA
            </h6>
            <div class="alert alert-info py-2 small mb-3">
              <i class="fas fa-info-circle me-1"></i>
              Questi URL puntano ai <strong>metadata SAML2 del proxy SATOSA stesso</strong>
              (non al registro nazionale SPID), usati dal frontoffice per configurare il suo SP.
              Vengono calcolati automaticamente dall'URL pubblico del proxy.
            </div>
            <div class="row g-3 mb-4">
              <div class="col-md-8">
                <label class="form-label">URL metadata SATOSA IdP (pubblico)</label>
                <div class="input-group">
                  <input type="url" class="form-control font-monospace" name="saml2_idp_metadata_url"
                    id="lp-saml2-meta-pub"
                    value="{{ iam_proxy.saml2_idp_metadata_url|default('') }}"
                    {{ not is_superadmin ? 'readonly' : 'readonly data-derived="true"' }}>
                  {% if is_superadmin %}
                  <button class="btn btn-outline-secondary" type="button" onclick="lpUnlock('lp-saml2-meta-pub', this)" title="Modifica manualmente">
                    <i class="fas fa-pencil-alt"></i>
                  </button>
                  {% endif %}
                </div>
                <div class="form-text">Calcolato: <code id="lp-saml2-meta-pub-hint"></code></div>
              </div>
              <div class="col-md-8">
                <label class="form-label">URL metadata SATOSA IdP (interno/container)</label>
                <div class="input-group">
                  <input type="url" class="form-control font-monospace" name="saml2_idp_metadata_url_internal"
                    id="lp-saml2-meta-int"
                    value="{{ iam_proxy.saml2_idp_metadata_url_internal|default('') }}"
                    {{ not is_superadmin ? 'readonly' : 'readonly data-derived="true"' }}>
                  {% if is_superadmin %}
                  <button class="btn btn-outline-secondary" type="button" onclick="lpUnlock('lp-saml2-meta-int', this)" title="Modifica manualmente">
                    <i class="fas fa-pencil-alt"></i>
                  </button>
                  {% endif %}
                </div>
                <div class="form-text">Calcolato: <code id="lp-saml2-meta-int-hint"></code></div>
              </div>
            </div>

            {# Parametri certificato SP #}
            <h6 class="text-muted text-uppercase small fw-semibold mb-2">
              <i class="fas fa-certificate me-1"></i>Parametri certificato SP
            </h6>
            <p class="text-muted small mb-3">
              Usati per generare il certificato SAML2 del Service Provider.
              I campi pre-compilati sono derivati dai <a href="/impostazioni?tab=generale">Dati ente</a>.
            </p>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Common Name (CN)</label>
                <input type="text" class="form-control" name="spid_cert_common_name"
                  id="lp-spid-cn"
                  value="{{ iam_proxy.spid_cert_common_name|default('') }}"
                  placeholder="{{ iam_proxy.hostname|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
                <div class="form-text">Di norma: hostname del proxy (es. <code>login.comune.example.it</code>).</div>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Name</label>
                <input type="text" class="form-control" name="spid_cert_org_name"
                  value="{{ iam_proxy.spid_cert_org_name|default(entity.name|default('')) }}"
                  placeholder="{{ entity.name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-4">
                <label class="form-label">Organization ID</label>
                <div class="input-group">
                  <input type="text" class="form-control font-monospace" name="spid_cert_org_id"
                    id="lp-spid-org-id"
                    value="{{ iam_proxy.spid_cert_org_id|default('') }}"
                    placeholder="PA:IT-{{ entity.ipa_code|default('c_xxxx') }}"
                    {{ not is_superadmin ? 'readonly' : 'readonly data-derived="true"' }}>
                  {% if is_superadmin %}
                  <button class="btn btn-outline-secondary" type="button" onclick="lpUnlock('lp-spid-org-id', this)" title="Modifica manualmente">
                    <i class="fas fa-pencil-alt"></i>
                  </button>
                  {% endif %}
                </div>
                <div class="form-text">Formato: <code>PA:IT-{codice IPA}</code> — es. <code>PA:IT-c_f646</code>.</div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Entity ID</label>
                <div class="input-group">
                  <input type="url" class="form-control font-monospace" name="spid_cert_entity_id"
                    id="lp-spid-entity-id"
                    value="{{ iam_proxy.spid_cert_entity_id|default('') }}"
                    placeholder="{{ frontoffice.public_url|default('') }}/saml/sp"
                    {{ not is_superadmin ? 'readonly' : 'readonly data-derived="true"' }}>
                  {% if is_superadmin %}
                  <button class="btn btn-outline-secondary" type="button" onclick="lpUnlock('lp-spid-entity-id', this)" title="Modifica manualmente">
                    <i class="fas fa-pencil-alt"></i>
                  </button>
                  {% endif %}
                </div>
                <div class="form-text">Calcolato: <code id="lp-spid-entity-id-hint"></code></div>
              </div>
              <div class="col-md-4">
                <label class="form-label">Locality (città)</label>
                <input type="text" class="form-control" name="spid_cert_locality_name"
                  value="{{ iam_proxy.spid_cert_locality_name|default('') }}"
                  placeholder="Es. Montesilvano"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-3">
                <label class="form-label">Key size (bit)</label>
                <select class="form-select" name="spid_cert_key_size" {{ not is_superadmin ? 'disabled' : '' }}>
                  <option value="2048" {{ iam_proxy.spid_cert_key_size|default('2048') == '2048' ? 'selected' : '' }}>2048</option>
                  <option value="4096" {{ iam_proxy.spid_cert_key_size|default('') == '4096' ? 'selected' : '' }}>4096</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Validità (giorni)</label>
                <input type="number" class="form-control" name="spid_cert_days"
                  value="{{ iam_proxy.spid_cert_days|default('730') }}" min="30" max="3650"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ─── CIE OIDC ──────────────────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-cie">
            <i class="fas fa-address-card me-2 text-info"></i>CIE OIDC
          </button>
        </h2>
        <div id="lp-cie" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            {% set cie_prod_url   = 'https://oidc.idserver.servizicie.interno.gov.it' %}
            {% set cie_preprod_url = 'https://preproduzione.cie.interno.gov.it/idp/oidc/op' %}
            {% set current_cie_url = iam_proxy.cie_oidc_provider_url|default(cie_prod_url) %}
            {% set cie_env = current_cie_url == cie_prod_url ? 'prod' : (current_cie_url == cie_preprod_url ? 'preprod' : 'custom') %}

            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label class="form-label">Ambiente CIE OIDC</label>
                <select class="form-select" id="lp-cie-env" {{ not is_superadmin ? 'disabled' : '' }}
                  onchange="lpUpdateCieEnv()">
                  <option value="prod"    {{ cie_env == 'prod'    ? 'selected' : '' }}>Produzione</option>
                  <option value="preprod" {{ cie_env == 'preprod' ? 'selected' : '' }}>Pre-produzione (collaudo)</option>
                  <option value="custom"  {{ cie_env == 'custom'  ? 'selected' : '' }}>Personalizzato…</option>
                </select>
              </div>
              <div class="col-md-8" id="lp-cie-custom-wrap" style="{{ cie_env != 'custom' ? 'display:none' : '' }}">
                <label class="form-label">Provider URL personalizzato</label>
                <input type="url" class="form-control font-monospace" id="lp-cie-custom-url"
                  value="{{ cie_env == 'custom' ? current_cie_url : '' }}"
                  placeholder="https://…"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              {# Campo nascosto con il valore effettivo da salvare #}
              <input type="hidden" name="cie_oidc_provider_url" id="lp-cie-provider-url-hidden"
                value="{{ current_cie_url }}">
            </div>

            <hr class="my-3">
            <p class="text-muted small mb-3">
              <i class="fas fa-magic me-1"></i>
              I campi seguenti vengono calcolati automaticamente dall'<strong>URL pubblico del proxy</strong>.
              Clicca <i class="fas fa-pencil-alt"></i> per modificarli manualmente.
            </p>

            {# Macro campi calcolati #}
            {% macro derived_field(label, name, id, hint_id, value, is_superadmin) %}
            <div class="col-md-8">
              <label class="form-label">{{ label }}</label>
              <div class="input-group">
                <input type="url" class="form-control font-monospace" name="{{ name }}" id="{{ id }}"
                  value="{{ value }}"
                  {{ not is_superadmin ? 'readonly' : 'readonly data-derived="true"' }}>
                {% if is_superadmin %}
                <button class="btn btn-outline-secondary" type="button"
                  onclick="lpUnlock('{{ id }}', this)" title="Modifica manualmente">
                  <i class="fas fa-pencil-alt"></i>
                </button>
                {% endif %}
              </div>
              {% if hint_id %}<div class="form-text"><code id="{{ hint_id }}"></code></div>{% endif %}
            </div>
            {% endmacro %}

            <div class="row g-3 mb-3">
              {{ _self.derived_field('Client ID', 'cie_oidc_client_id', 'lp-cie-client-id', 'lp-cie-client-id-hint',
                iam_proxy.cie_oidc_client_id|default(''), is_superadmin) }}
              {{ _self.derived_field('Redirect URI', 'cie_oidc_redirect_uri', 'lp-cie-redirect', 'lp-cie-redirect-hint',
                iam_proxy.cie_oidc_redirect_uri|default(''), is_superadmin) }}
              {{ _self.derived_field('JWKS URI', 'cie_oidc_jwks_uri', 'lp-cie-jwks', 'lp-cie-jwks-hint',
                iam_proxy.cie_oidc_jwks_uri|default(''), is_superadmin) }}
              {{ _self.derived_field('Signed JWKS URI', 'cie_oidc_signed_jwks_uri', 'lp-cie-signed-jwks', 'lp-cie-signed-jwks-hint',
                iam_proxy.cie_oidc_signed_jwks_uri|default(''), is_superadmin) }}
              {{ _self.derived_field('Trust Anchor URL', 'cie_oidc_trust_anchor_url', 'lp-cie-trust-anchor', 'lp-cie-trust-anchor-hint',
                iam_proxy.cie_oidc_trust_anchor_url|default(''), is_superadmin) }}
              {{ _self.derived_field('Authority Hint URL', 'cie_oidc_authority_hint_url', 'lp-cie-auth-hint', 'lp-cie-auth-hint-hint',
                iam_proxy.cie_oidc_authority_hint_url|default(''), is_superadmin) }}
              {{ _self.derived_field('Homepage URI', 'cie_oidc_homepage_uri', 'lp-cie-homepage', 'lp-cie-homepage-hint',
                iam_proxy.cie_oidc_homepage_uri|default(''), is_superadmin) }}
            </div>

            <hr class="my-3">
            <h6 class="text-muted text-uppercase small fw-semibold mb-2">Informazioni organizzazione</h6>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label">Client Name</label>
                <input type="text" class="form-control" name="cie_oidc_client_name"
                  value="{{ iam_proxy.cie_oidc_client_name|default('') }}"
                  placeholder="{{ entity.name|default('') ~ ' - CIE OIDC RP' }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Name</label>
                <input type="text" class="form-control" name="cie_oidc_organization_name"
                  value="{{ iam_proxy.cie_oidc_organization_name|default(entity.name|default('')) }}"
                  placeholder="{{ entity.name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">E-mail di contatto</label>
                <input type="email" class="form-control" name="cie_oidc_contact_email"
                  value="{{ iam_proxy.cie_oidc_contact_email|default(entity.support_email|default('')) }}"
                  placeholder="{{ entity.support_email|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
            </div>

            {# Endpoint federazione (avanzati) #}
            {% if is_superadmin %}
            <details class="mt-2">
              <summary class="text-muted small fw-semibold" style="cursor:pointer">
                <i class="fas fa-caret-right me-1"></i>Endpoint federazione (avanzati, auto-calcolati)
              </summary>
              <div class="row g-3 mt-2">
                {{ _self.derived_field('Federation Resolve', 'cie_oidc_federation_resolve_endpoint', 'lp-cie-fed-resolve', null,
                  iam_proxy.cie_oidc_federation_resolve_endpoint|default(''), is_superadmin) }}
                {{ _self.derived_field('Federation Fetch', 'cie_oidc_federation_fetch_endpoint', 'lp-cie-fed-fetch', null,
                  iam_proxy.cie_oidc_federation_fetch_endpoint|default(''), is_superadmin) }}
                {{ _self.derived_field('Trust Mark Status', 'cie_oidc_federation_trust_mark_status_endpoint', 'lp-cie-fed-tm', null,
                  iam_proxy.cie_oidc_federation_trust_mark_status_endpoint|default(''), is_superadmin) }}
                {{ _self.derived_field('Federation List', 'cie_oidc_federation_list_endpoint', 'lp-cie-fed-list', null,
                  iam_proxy.cie_oidc_federation_list_endpoint|default(''), is_superadmin) }}
                <div class="col-md-8">
                  <label class="form-label">Policy URI</label>
                  <div class="input-group">
                    <input type="url" class="form-control font-monospace" name="cie_oidc_policy_uri"
                      id="lp-cie-policy" value="{{ iam_proxy.cie_oidc_policy_uri|default('') }}"
                      readonly data-derived="true">
                    <button class="btn btn-outline-secondary" type="button" onclick="lpUnlock('lp-cie-policy', this)">
                      <i class="fas fa-pencil-alt"></i>
                    </button>
                  </div>
                </div>
                <div class="col-md-8">
                  <label class="form-label">Logo URI</label>
                  <div class="input-group">
                    <input type="url" class="form-control font-monospace" name="cie_oidc_logo_uri"
                      id="lp-cie-logo" value="{{ iam_proxy.cie_oidc_logo_uri|default('') }}"
                      readonly data-derived="true">
                    <button class="btn btn-outline-secondary" type="button" onclick="lpUnlock('lp-cie-logo', this)">
                      <i class="fas fa-pencil-alt"></i>
                    </button>
                  </div>
                </div>
              </div>
            </details>
            {% else %}
            {# Mantieni i valori nascosti per utenti non-superadmin #}
            <input type="hidden" name="cie_oidc_federation_resolve_endpoint" value="{{ iam_proxy.cie_oidc_federation_resolve_endpoint|default('') }}">
            <input type="hidden" name="cie_oidc_federation_fetch_endpoint" value="{{ iam_proxy.cie_oidc_federation_fetch_endpoint|default('') }}">
            <input type="hidden" name="cie_oidc_federation_trust_mark_status_endpoint" value="{{ iam_proxy.cie_oidc_federation_trust_mark_status_endpoint|default('') }}">
            <input type="hidden" name="cie_oidc_federation_list_endpoint" value="{{ iam_proxy.cie_oidc_federation_list_endpoint|default('') }}">
            <input type="hidden" name="cie_oidc_policy_uri" value="{{ iam_proxy.cie_oidc_policy_uri|default('') }}">
            <input type="hidden" name="cie_oidc_logo_uri" value="{{ iam_proxy.cie_oidc_logo_uri|default('') }}">
            {% endif %}

          </div>
        </div>
      </div>

      {# ─── Organizzazione SATOSA ─────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-satosa">
            <i class="fas fa-sitemap me-2 text-secondary"></i>Organizzazione SATOSA
          </button>
        </h2>
        <div id="lp-satosa" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="alert alert-info py-2 small mb-3">
              <i class="fas fa-info-circle me-1"></i>
              Valori usati nel metadata SP e nei campi di contatto SATOSA.
              I campi pre-compilati sono derivati dai <a href="/impostazioni?tab=generale">Dati ente</a>.
            </div>

            {# Derivato automaticamente IPA: org_identifier formato PA:IT-XXXX (maiuscolo senza c_) #}
            {% set ipa_upper = entity.ipa_code|default('')|replace({'c_': ''})|upper %}

            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label">Organization Display Name (IT)</label>
                <input type="text" class="form-control" name="satosa_org_display_name_it"
                  value="{{ iam_proxy.satosa_org_display_name_it|default('') }}"
                  placeholder="{{ entity.name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Name (IT)</label>
                <input type="text" class="form-control" name="satosa_org_name_it"
                  value="{{ iam_proxy.satosa_org_name_it|default(entity.name|default('')) }}"
                  placeholder="{{ entity.name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Identifier</label>
