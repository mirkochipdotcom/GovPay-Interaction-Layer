<div id="lp-wrap">
  {# ─── Status bar ─────────────────────────────────────────────────────────── #}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2 py-3">
      <div class="d-flex align-items-center gap-2">
        <span id="lp-status-dot" class="master-status-dot bg-secondary"></span>
        <strong>Login Proxy (IAM Proxy)</strong>
        <span id="lp-status-text" class="text-muted small">Stato sconosciuto</span>
      </div>
      {% if is_superadmin %}
      <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-sm btn-success" onclick="impAction('/impostazioni/login-proxy/avvia', this, 'Avvio…')">
          <i class="fas fa-play me-1"></i>Avvia
        </button>
        <button class="btn btn-sm btn-danger" onclick="impAction('/impostazioni/login-proxy/arresta', this, 'Arresto…')">
          <i class="fas fa-stop me-1"></i>Arresta
        </button>
        <button class="btn btn-sm btn-warning" onclick="impAction('/impostazioni/login-proxy/riavvia', this, 'Riavvio…')">
          <i class="fas fa-sync-alt me-1"></i>Riavvia
        </button>
        <button class="btn btn-sm btn-outline-secondary" onclick="impAction('/impostazioni/login-proxy/rigenera-sp-metadata', this, 'Rigenerazione…')">
          <i class="fas fa-redo me-1"></i>Rigenera SP Metadata
        </button>
      </div>
      {% endif %}
    </div>
  </div>

  <form id="form-login-proxy" onsubmit="return false;">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    {# ─── Generale ─────────────────────────────────────────────────────────── #}
    <div class="accordion mb-3" id="acc-lp">

      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#lp-generale">
            <i class="fas fa-globe me-2 text-primary"></i>Generale
          </button>
        </h2>
        <div id="lp-generale" class="accordion-collapse collapse show" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label">URL pubblico del proxy</label>
                <input type="url" class="form-control" name="public_base_url"
                  value="{{ iam_proxy.public_base_url|default('') }}" placeholder="https://login.comune.example.it"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-4">
                <label class="form-label">Hostname interno</label>
                <input type="text" class="form-control font-monospace" name="hostname"
                  value="{{ iam_proxy.hostname|default('') }}" placeholder="login.comune.example.it"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-3">
                <label class="form-label">Porta HTTP</label>
                <input type="number" class="form-control" name="http_port"
                  value="{{ iam_proxy.http_port|default('8080') }}" min="1" max="65535"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-5">
                <label class="form-label">SATOSA base path</label>
                <input type="text" class="form-control font-monospace" name="satosa_base"
                  value="{{ iam_proxy.satosa_base|default('/saml2/idp') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-12">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="debug" id="lp-debug" value="true"
                    {{ iam_proxy.debug|default('false') == 'true' ? 'checked' : '' }}
                    {{ not is_superadmin ? 'disabled' : '' }}>
                  <label class="form-check-label" for="lp-debug">Modalità debug (verbose logging)</label>
                </div>
              </div>
            </div>

            <hr class="my-3">
            <p class="text-muted small mb-2">Metodi di autenticazione abilitati:</p>
            <div class="d-flex gap-4 flex-wrap">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_spid" id="en-spid" value="true"
                  {{ iam_proxy.enable_spid|default('false') == 'true' ? 'checked' : '' }}
                  {{ not is_superadmin ? 'disabled' : '' }}>
                <label class="form-check-label" for="en-spid">SPID</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_cie_oidc" id="en-cie" value="true"
                  {{ iam_proxy.enable_cie_oidc|default('false') == 'true' ? 'checked' : '' }}
                  {{ not is_superadmin ? 'disabled' : '' }}>
                <label class="form-check-label" for="en-cie">CIE OIDC</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_it_wallet" id="en-wallet" value="true"
                  {{ iam_proxy.enable_it_wallet|default('false') == 'true' ? 'checked' : '' }}
                  {{ not is_superadmin ? 'disabled' : '' }}>
                <label class="form-check-label" for="en-wallet">IT Wallet</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_oidcop" id="en-oidcop" value="true"
                  {{ iam_proxy.enable_oidcop|default('false') == 'true' ? 'checked' : '' }}
                  {{ not is_superadmin ? 'disabled' : '' }}>
                <label class="form-check-label" for="en-oidcop">OIDC OP</label>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ─── SPID / SAML2 ───────────────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-spid">
            <i class="fas fa-id-card me-2 text-success"></i>SPID / SAML2
          </button>
        </h2>
        <div id="lp-spid" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="row g-3 mb-3">
              <div class="col-md-8">
                <label class="form-label">URL metadata IdP SPID (pubblico)</label>
                <input type="url" class="form-control" name="saml2_idp_metadata_url"
                  value="{{ iam_proxy.saml2_idp_metadata_url|default('') }}"
                  placeholder="https://registry.spid.gov.it/metadata/idp/spid-entities-idps.xml"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-8">
                <label class="form-label">URL metadata IdP (interno/cache)</label>
                <input type="url" class="form-control" name="saml2_idp_metadata_url_internal"
                  value="{{ iam_proxy.saml2_idp_metadata_url_internal|default('') }}"
                  placeholder="http://spid-metadata-cache:8080/…"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
            </div>
            <hr class="my-3">
            <p class="small text-muted mb-2">Parametri certificato SP (generato automaticamente se assenti):</p>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Common Name (CN)</label>
                <input type="text" class="form-control" name="spid_cert_common_name"
                  value="{{ iam_proxy.spid_cert_common_name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Name</label>
                <input type="text" class="form-control" name="spid_cert_org_name"
                  value="{{ iam_proxy.spid_cert_org_name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-4">
                <label class="form-label">Organization ID</label>
                <input type="text" class="form-control font-monospace" name="spid_cert_org_id"
                  value="{{ iam_proxy.spid_cert_org_id|default('') }}" placeholder="PA:IT-c_…"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-4">
                <label class="form-label">Entity ID</label>
                <input type="text" class="form-control font-monospace" name="spid_cert_entity_id"
                  value="{{ iam_proxy.spid_cert_entity_id|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-4">
                <label class="form-label">Locality (città)</label>
                <input type="text" class="form-control" name="spid_cert_locality_name"
                  value="{{ iam_proxy.spid_cert_locality_name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-3">
                <label class="form-label">Key size (bit)</label>
                <select class="form-select" name="spid_cert_key_size" {{ not is_superadmin ? 'disabled' : '' }}>
                  <option value="2048" {{ iam_proxy.spid_cert_key_size|default('2048') == '2048' ? 'selected' : '' }}>2048</option>
                  <option value="4096" {{ iam_proxy.spid_cert_key_size|default('') == '4096' ? 'selected' : '' }}>4096</option>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">Validità (giorni)</label>
                <input type="number" class="form-control" name="spid_cert_days"
                  value="{{ iam_proxy.spid_cert_days|default('730') }}" min="30" max="3650"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ─── CIE OIDC ────────────────────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-cie">
            <i class="fas fa-address-card me-2 text-info"></i>CIE OIDC
          </button>
        </h2>
        <div id="lp-cie" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label">CIE OIDC Provider URL</label>
                <input type="url" class="form-control" name="cie_oidc_provider_url"
                  value="{{ iam_proxy.cie_oidc_provider_url|default('https://preproduzione.cie.interno.gov.it/idp/oidc/op') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-5">
                <label class="form-label">Client ID</label>
                <input type="text" class="form-control font-monospace" name="cie_oidc_client_id"
                  value="{{ iam_proxy.cie_oidc_client_id|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-5">
                <label class="form-label">Client Name</label>
                <input type="text" class="form-control" name="cie_oidc_client_name"
                  value="{{ iam_proxy.cie_oidc_client_name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-8">
                <label class="form-label">JWKS URI</label>
                <input type="url" class="form-control" name="cie_oidc_jwks_uri"
                  value="{{ iam_proxy.cie_oidc_jwks_uri|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-8">
                <label class="form-label">Redirect URI</label>
                <input type="url" class="form-control" name="cie_oidc_redirect_uri"
                  value="{{ iam_proxy.cie_oidc_redirect_uri|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ─── Organizzazione SATOSA ───────────────────────────────────────────── #}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-satosa">
            <i class="fas fa-sitemap me-2 text-secondary"></i>Organizzazione SATOSA
          </button>
        </h2>
        <div id="lp-satosa" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="alert alert-info py-2 small mb-3">
              <i class="fas fa-info-circle me-1"></i>
              Questi valori vengono usati per il metadata SP e per i campi di contatto SATOSA.
              Se lasciati vuoti, vengono derivati automaticamente dai <strong>dati ente</strong>.
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Organization Display Name (IT)</label>
                <input type="text" class="form-control" name="satosa_org_display_name_it"
                  value="{{ iam_proxy.satosa_org_display_name_it|default('') }}"
                  placeholder="{{ entity.name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Name (IT)</label>
                <input type="text" class="form-control" name="satosa_org_name_it"
                  value="{{ iam_proxy.satosa_org_name_it|default('') }}"
                  placeholder="{{ entity.name|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-6">
                <label class="form-label">Organization Identifier (URI)</label>
                <input type="text" class="form-control font-monospace" name="satosa_org_identifier"
                  value="{{ iam_proxy.satosa_org_identifier|default('') }}"
                  placeholder="https://www.comune.example.it"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-4">
                <label class="form-label">Codice IPA contatto</label>
                <input type="text" class="form-control font-monospace" name="satosa_contact_ipa_code"
                  value="{{ iam_proxy.satosa_contact_ipa_code|default('') }}"
                  placeholder="{{ entity.ipa_code|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-5">
                <label class="form-label">Codice fiscale ente</label>
                <input type="text" class="form-control font-monospace" name="satosa_contact_fiscalcode"
                  value="{{ iam_proxy.satosa_contact_fiscalcode|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-5">
                <label class="form-label">E-mail contatto tecnico</label>
                <input type="email" class="form-control" name="satosa_contact_email"
                  value="{{ iam_proxy.satosa_contact_email|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
              <div class="col-md-3">
                <label class="form-label">Telefono contatto</label>
                <input type="text" class="form-control" name="satosa_contact_phone"
                  value="{{ iam_proxy.satosa_contact_phone|default('') }}"
                  {{ not is_superadmin ? 'readonly' : '' }}>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ─── Chiavi crittografiche SATOSA (solo superadmin) ─────────────────── #}
      {% if is_superadmin %}
      <div class="accordion-item border shadow-sm mb-2">
        <h2 class="accordion-header">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lp-satosa-keys">
            <i class="fas fa-key me-2 text-danger"></i>Chiavi crittografiche SATOSA
            <span class="badge bg-danger-subtle text-danger border border-danger-subtle ms-2 fw-normal small">Segreti</span>
          </button>
        </h2>
        <div id="lp-satosa-keys" class="accordion-collapse collapse" data-bs-parent="#acc-lp">
          <div class="accordion-body">
            <div class="alert alert-warning py-2 small mb-3">
              <i class="fas fa-exclamation-triangle me-1"></i>
              Queste chiavi vengono usate da SATOSA per firmare/cifrare le sessioni. Devono essere
              stringhe casuali di <strong>almeno 32 caratteri</strong>. Generale con:
              <code>openssl rand -hex 24</code>.
              Lasciare vuoto per non sovrascrivere il valore esistente.
            </div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label">Salt</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_salt"
                    id="satosa-salt" placeholder="Lascia vuoto per non modificare"
                    autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-salt', this)" title="Mostra/nascondi">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">State Encryption Key</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_state_encryption_key"
                    id="satosa-state-key" placeholder="Lascia vuoto per non modificare"
                    autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-state-key', this)" title="Mostra/nascondi">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">Encryption Key</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_encryption_key"
                    id="satosa-enc-key" placeholder="Lascia vuoto per non modificare"
                    autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-enc-key', this)" title="Mostra/nascondi">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label">User ID Hash Salt</label>
                <div class="input-group">
                  <input type="password" class="form-control font-monospace" name="satosa_user_id_hash_salt"
                    id="satosa-id-salt" placeholder="Lascia vuoto per non modificare"
                    autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('satosa-id-salt', this)" title="Mostra/nascondi">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
              </div>
            </div>

            <hr class="my-3">
            <p class="small text-muted mb-2">Toggle avanzati:</p>
            <div class="d-flex gap-4 flex-wrap">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_idem" id="en-idem" value="true"
                  {{ iam_proxy.enable_idem|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="en-idem">IDEM</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="enable_eidas" id="en-eidas" value="true"
                  {{ iam_proxy.enable_eidas|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="en-eidas">eIDAS</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="satosa_use_demo_spid_idp" id="demo-spid" value="true"
                  {{ iam_proxy.satosa_use_demo_spid_idp|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="demo-spid">Demo SPID IdP</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="satosa_use_spid_validator" id="spid-validator" value="true"
                  {{ iam_proxy.satosa_use_spid_validator|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="spid-validator">SPID Validator</label>
              </div>
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="satosa_disable_cieoidc_backend" id="dis-cie" value="true"
                  {{ iam_proxy.satosa_disable_cieoidc_backend|default('false') == 'true' ? 'checked' : '' }}>
                <label class="form-check-label" for="dis-cie">Disabilita backend CIE OIDC</label>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endif %}

    </div>{# /accordion #}

    {% if is_superadmin %}
    <div class="d-flex justify-content-end">
      <button type="button" class="btn btn-primary" onclick="impSaveForm('form-login-proxy', '/impostazioni/login-proxy/save', this)">
        <i class="fas fa-save me-1"></i>Salva configurazione
      </button>
    </div>
    {% endif %}
  </form>
</div>

{# ─── Metadata SPID / CIE ────────────────────────────────────────────────────── #}
<div class="row g-3 mt-2">
  {# SPID #}
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
        <h6 class="mb-0"><i class="fas fa-id-card me-2 text-success"></i>Metadata SP SPID</h6>
        <button class="btn btn-sm btn-outline-secondary" onclick="loadMetadataInfo('spid', this)" title="Aggiorna info">
          <i class="fas fa-sync-alt"></i>
        </button>
      </div>
      <div class="card-body" id="spid-metadata-body">
        <p class="text-muted small mb-0">Clicca <i class="fas fa-sync-alt"></i> per caricare le informazioni.</p>
      </div>
      <div class="card-footer bg-white d-flex gap-2 flex-wrap">
        <a href="/impostazioni/login-proxy/spid-metadata/download" class="btn btn-sm btn-outline-primary">
          <i class="fas fa-download me-1"></i>Scarica backup
        </a>
        {% if is_superadmin %}
        <button class="btn btn-sm btn-outline-warning" type="button" onclick="toggleRestoreForm('spid-restore-form')">
          <i class="fas fa-upload me-1"></i>Ripristina
        </button>
        {% endif %}
      </div>
      {% if is_superadmin %}
      <div id="spid-restore-form" class="card-body border-top pt-3" style="display:none;">
        <label class="form-label small fw-semibold">Carica file XML metadata SP</label>
        <div class="input-group">
          <input type="file" class="form-control form-control-sm" id="spid-restore-file" accept=".xml">
          <button class="btn btn-sm btn-warning" type="button" onclick="restoreMetadata('spid', 'spid-restore-file', this)">
            <i class="fas fa-upload me-1"></i>Ripristina
          </button>
        </div>
        <div class="form-text">File XML SAML2 del Service Provider SPID.</div>
      </div>
      {% endif %}
    </div>
  </div>

  {# CIE #}
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
        <h6 class="mb-0"><i class="fas fa-address-card me-2 text-info"></i>Metadata SP CIE OIDC</h6>
        <button class="btn btn-sm btn-outline-secondary" onclick="loadMetadataInfo('cie', this)" title="Aggiorna info">
          <i class="fas fa-sync-alt"></i>
        </button>
      </div>
      <div class="card-body" id="cie-metadata-body">
        <p class="text-muted small mb-0">Clicca <i class="fas fa-sync-alt"></i> per caricare le informazioni.</p>
      </div>
      <div class="card-footer bg-white d-flex gap-2 flex-wrap">
        <a href="/impostazioni/login-proxy/cie-metadata/download" class="btn btn-sm btn-outline-primary">
          <i class="fas fa-download me-1"></i>Scarica backup
        </a>
        {% if is_superadmin %}
        <button class="btn btn-sm btn-outline-warning" type="button" onclick="toggleRestoreForm('cie-restore-form')">
          <i class="fas fa-upload me-1"></i>Ripristina
        </button>
        {% endif %}
      </div>
      {% if is_superadmin %}
      <div id="cie-restore-form" class="card-body border-top pt-3" style="display:none;">
        <label class="form-label small fw-semibold">Carica file JSON entity configuration CIE</label>
        <div class="input-group">
          <input type="file" class="form-control form-control-sm" id="cie-restore-file" accept=".json">
          <button class="btn btn-sm btn-warning" type="button" onclick="restoreMetadata('cie', 'cie-restore-file', this)">
            <i class="fas fa-upload me-1"></i>Ripristina
          </button>
        </div>
        <div class="form-text">File JSON dell'entity configuration CIE OIDC.</div>
      </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
// Load container status on page load
(async function () {
  try {
    const res = await fetch('/impostazioni/containers/status');
    if (!res.ok) return;
    const data = await res.json();
    const services = data.services || {};
    const iamRunning = Object.entries(services).some(([name, info]) =>
      (name.includes('iam-proxy') || name.includes('satosa')) && info.running
    );
    const dot  = document.getElementById('lp-status-dot');
    const text = document.getElementById('lp-status-text');
    if (dot && text) {
      dot.className = 'master-status-dot ' + (iamRunning ? 'bg-success' : 'bg-danger');
      text.textContent = iamRunning ? 'In esecuzione' : 'Fermo';
    }
  } catch (_) { /* master non disponibile, silenzioso */ }
})();

function togglePwd(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  if (el.type === 'password') {
    el.type = 'text';
    btn.querySelector('i').className = 'fas fa-eye-slash';
  } else {
    el.type = 'password';
    btn.querySelector('i').className = 'fas fa-eye';
  }
}

function toggleRestoreForm(id) {
  const el = document.getElementById(id);
  if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
}

async function loadMetadataInfo(type, btn) {
  const bodyEl = document.getElementById(type + '-metadata-body');
  if (!bodyEl) return;
  const origIcon = btn ? btn.innerHTML : '';
  if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }
  try {
    const res = await fetch('/impostazioni/login-proxy/' + type + '-metadata/info');
    const json = await res.json();
    const d = json.data || json;
    if (!d.exists) {
      bodyEl.innerHTML = '<span class="badge bg-warning-subtle text-warning border border-warning-subtle"><i class="fas fa-exclamation-circle me-1"></i>File non trovato</span>';
      return;
    }
    if (d.parse_error) {
      bodyEl.innerHTML = '<div class="text-danger small"><i class="fas fa-times-circle me-1"></i>Errore parsing: ' + escHtml(d.parse_error) + '</div>';
      return;
    }
    let html = '<dl class="row small mb-0">';
    if (type === 'spid') {
      html += metaRow('Entity ID', escHtml(d.entity_id || '—'));
      if (d.acs_urls && d.acs_urls.length) {
        html += metaRow('ACS URL', d.acs_urls.map(u => '<code class="small">' + escHtml(u) + '</code>').join('<br>'));
      }
      html += metaRow('Scadenza metadata', expiryBadge(d.valid_until, d.valid_until_expired));
      html += metaRow('Scadenza certificato', expiryBadge(d.cert_expiry, d.cert_expired));
    } else {
      html += metaRow('Issuer', escHtml(d.iss || '—'));
      html += metaRow('Subject', escHtml(d.sub || '—'));
      html += metaRow('Scadenza (exp)', expiryBadge(d.exp, d.exp_expired));
      html += metaRow('Emesso (iat)', '<span class="text-muted">' + escHtml(d.iat || '—') + '</span>');
      html += metaRow('Chiavi JWK', '<span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">' + (d.jwk_count || 0) + ' chiavi</span>');
    }
    html += metaRow('Aggiornato', '<span class="text-muted">' + escHtml(d.file_mtime || '—') + '</span>');
    html += '</dl>';
    bodyEl.innerHTML = html;
  } catch (e) {
    bodyEl.innerHTML = '<div class="text-danger small">Errore: ' + escHtml(e.message) + '</div>';
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = origIcon; }
  }
}

function metaRow(label, value) {
  return '<dt class="col-5 text-muted fw-normal">' + label + '</dt><dd class="col-7 mb-1">' + value + '</dd>';
}

function expiryBadge(date, expired) {
  if (!date) return '<span class="text-muted">—</span>';
  const cls = expired ? 'bg-danger-subtle text-danger border-danger-subtle' : 'bg-success-subtle text-success border-success-subtle';
  const icon = expired ? 'fa-times-circle' : 'fa-check-circle';
  return '<span class="badge ' + cls + ' border"><i class="fas ' + icon + ' me-1"></i>' + escHtml(date) + '</span>';
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function restoreMetadata(type, fileInputId, btn) {
  const fileEl = document.getElementById(fileInputId);
  if (!fileEl || !fileEl.files[0]) { impToast('Seleziona un file.', false); return; }
  const fd = new FormData();
  fd.append('metadata_file', fileEl.files[0]);
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Caricamento…';
  try {
    const res = await fetch('/impostazioni/login-proxy/' + type + '-metadata/restore', { method: 'POST', body: fd });
    const json = await res.json();
    impToast(json.message || (json.success ? 'Ripristinato.' : 'Fallito.'), !!json.success);
    if (json.success) {
      toggleRestoreForm(type + '-restore-form');
      loadMetadataInfo(type, null);
    }
  } catch (e) { impToast('Errore: ' + e.message, false); }
  finally { btn.disabled = false; btn.innerHTML = orig; }
}
</script>
