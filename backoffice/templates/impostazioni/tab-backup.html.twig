<div id="backup-wrap">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

  {# ─── Backup completo di sistema ─────────────────────────────────────────── #}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-database me-2 text-primary"></i>Backup completo di sistema</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Crea un archivio ZIP contenente: impostazioni DB, dump del database, certificati GovPay, certificati SPID e metadata SP.
        Adatto per disaster recovery e migrazione tra ambienti.
      </p>

      {% if is_superadmin %}
      <button class="btn btn-primary btn-sm me-2"
              onclick="backupCreateSistema(this)">
        <i class="fas fa-plus me-1"></i>Crea backup ora
      </button>
      {% endif %}

      <button class="btn btn-outline-secondary btn-sm"
              onclick="backupListSistema(this)">
        <i class="fas fa-list me-1"></i>Aggiorna lista
      </button>

      <div id="backup-sistema-list" class="mt-3"></div>
    </div>
  </div>

  {# ─── Export dati applicativi (selettivo) ────────────────────────────────── #}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-file-export me-2 text-success"></i>Export dati applicativi</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Esporta in formato JSON le configurazioni applicative selezionate (tipologie, template, servizi App IO, utenti).
        Il file può essere reimportato su qualsiasi istanza GIL.
      </p>

      <form id="form-export-json" onsubmit="return false;">
        <div class="row g-2 mb-3">
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="tipologie" id="exp-tipologie" checked>
              <label class="form-check-label" for="exp-tipologie">Tipologie pagamento</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="tipologie_esterne" id="exp-tipologie-esterne" checked>
              <label class="form-check-label" for="exp-tipologie-esterne">Tipologie esterne</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="templates" id="exp-templates" checked>
              <label class="form-check-label" for="exp-templates">Template pendenze</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="io_services" id="exp-io" checked>
              <label class="form-check-label" for="exp-io">Servizi App IO</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="utenti" id="exp-utenti">
              <label class="form-check-label" for="exp-utenti">Utenti backoffice</label>
            </div>
          </div>
        </div>

        {% if is_superadmin %}
        <button type="button" class="btn btn-success btn-sm"
                onclick="backupExportJson(this)">
          <i class="fas fa-download me-1"></i>Esporta JSON
        </button>
        {% endif %}
      </form>
    </div>
  </div>

  {# ─── Importa da file JSON ────────────────────────────────────────────────── #}
  {% if is_superadmin %}
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
      <h2 class="h6 mb-0"><i class="fas fa-file-import me-2 text-warning"></i>Importa da JSON</h2>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-3">
        Importa un file di backup JSON esportato in precedenza.
        Seleziona le sezioni da ripristinare: i dati esistenti saranno sovrascritti.
      </p>

      <form id="form-import-json" action="/configurazione/backup/import" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <div class="mb-3">
          <label class="form-label small fw-semibold">File di backup (.json)</label>
          <input type="file" class="form-control form-control-sm" name="backup_file" accept=".json" required>
        </div>

        <div class="row g-2 mb-3">
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="tipologie" id="imp-tipologie" checked>
              <label class="form-check-label" for="imp-tipologie">Tipologie pagamento</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="tipologie_esterne" id="imp-tipologie-esterne" checked>
              <label class="form-check-label" for="imp-tipologie-esterne">Tipologie esterne</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="templates" id="imp-templates" checked>
              <label class="form-check-label" for="imp-templates">Template pendenze</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="io_services" id="imp-io" checked>
              <label class="form-check-label" for="imp-io">Servizi App IO</label>
            </div>
          </div>
          <div class="col-sm-6 col-md-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="sections[]" value="utenti" id="imp-utenti">
              <label class="form-check-label" for="imp-utenti">Utenti backoffice</label>
            </div>
          </div>
        </div>

        <button type="submit" class="btn btn-warning btn-sm"
                onclick="return confirm('Sicuro? I dati selezionati saranno sovrascritti.')">
          <i class="fas fa-upload me-1"></i>Importa
        </button>
      </form>
    </div>
  </div>
  {% endif %}
</div>

<script>
(function () {
  function fmtSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(1) + ' MB';
  }

  function renderBackupList(items) {
    const el = document.getElementById('backup-sistema-list');
    if (!items || items.length === 0) {
      el.innerHTML = '<p class="text-muted small mb-0">Nessun archivio trovato.</p>';
      return;
    }
    let html = '<div class="table-responsive"><table class="table table-sm table-hover mb-0"><thead><tr>'
      + '<th>File</th><th>Dimensione</th><th>Data</th><th></th></tr></thead><tbody>';
    for (const f of items) {
      html += `<tr>
        <td class="font-monospace small">${f.name}</td>
        <td class="small">${fmtSize(f.size)}</td>
        <td class="small">${f.modified}</td>
        <td><a href="/backup/sistema/download?file=${encodeURIComponent(f.name)}" class="btn btn-xs btn-outline-secondary btn-sm py-0 px-2">
          <i class="fas fa-download me-1"></i>Scarica</a></td></tr>`;
    }
    html += '</tbody></table></div>';
    el.innerHTML = html;
  }

  window.backupCreateSistema = async function (btn) {
    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creazione…';
    const csrf = document.querySelector('input[name="csrf_token"]')?.value || '';
    try {
      const res = await fetch('/backup/sistema/crea', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ csrf_token: csrf }),
      });
      const json = await res.json();
      impToast(json.message || (json.success ? 'Backup creato.' : 'Errore.'), !!json.success);
      if (json.success) backupListSistema(null);
    } catch (e) {
      impToast('Errore di rete: ' + e.message, false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

  window.backupListSistema = async function (btn) {
    if (btn) { btn.disabled = true; }
    try {
      const res = await fetch('/backup/sistema/lista');
      const json = await res.json();
      renderBackupList(json.files || []);
    } catch (e) {
      document.getElementById('backup-sistema-list').innerHTML =
        '<p class="text-danger small">Errore nel caricamento della lista.</p>';
    } finally {
      if (btn) { btn.disabled = false; }
    }
  };

  window.backupExportJson = function (btn) {
    const form = document.getElementById('form-export-json');
    const sections = [...form.querySelectorAll('input[name="sections[]"]:checked')].map(c => c.value);
    if (!sections.length) {
      impToast('Seleziona almeno una sezione.', false);
      return;
    }
    const csrf = document.querySelector('input[name="csrf_token"]')?.value || '';

    const f = document.createElement('form');
    f.method = 'POST';
    f.action = '/configurazione/backup/export';
    f.style.display = 'none';
    const csrfInput = document.createElement('input');
    csrfInput.type = 'hidden'; csrfInput.name = 'csrf_token'; csrfInput.value = csrf;
    f.appendChild(csrfInput);
    sections.forEach(s => {
      const i = document.createElement('input');
      i.type = 'hidden'; i.name = 'sections[]'; i.value = s;
      f.appendChild(i);
    });
    document.body.appendChild(f);
    f.submit();
    document.body.removeChild(f);
  };

  // Carica automaticamente la lista all'apertura del tab
  backupListSistema(null);
})();
</script>
