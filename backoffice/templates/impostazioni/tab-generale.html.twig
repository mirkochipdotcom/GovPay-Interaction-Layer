<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3">
    <h2 class="h5 mb-0"><i class="fas fa-building me-2 text-primary"></i>Generale</h2>
  </div>
  <div class="card-body">
    <form id="form-generale" onsubmit="return false;">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

      {# ─── Dati ente ────────────────────────────────────────────────────── #}
      <h6 class="text-muted text-uppercase small fw-semibold mb-3">
        <i class="fas fa-building me-1"></i>Dati ente
      </h6>
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <label class="form-label">Codice IPA</label>
          <input type="text" class="form-control font-monospace" name="entity_ipa_code"
            value="{{ entity.ipa_code|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-8">
          <label class="form-label">Nome ente <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="entity_name"
            value="{{ entity.name|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
          <div class="form-text">Appare nell'intestazione del backoffice e del frontoffice.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Dicitura sotto il nome</label>
          <input type="text" class="form-control" name="entity_suffix"
            value="{{ entity.suffix|default('') }}" placeholder="Servizi ai cittadini"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-6">
          <label class="form-label">Forma istituzionale</label>
          <input type="text" class="form-control" name="entity_government"
            value="{{ entity.government|default('') }}" placeholder="Es.: Città Metropolitana"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-8">
          <label class="form-label">Sito web ente</label>
          <input type="url" class="form-control" name="entity_url"
            value="{{ entity.url|default('') }}" placeholder="https://www.comune.example.it"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-4">
          <label class="form-label">ID Dominio</label>
          <input type="text" class="form-control font-monospace" name="id_dominio"
            value="{{ entity.id_dominio|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-4">
          <label class="form-label">ID A2A</label>
          <input type="text" class="form-control font-monospace" name="id_a2a"
            value="{{ entity.id_a2a|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
      </div>

      {# ─── Supporto ─────────────────────────────────────────────────────── #}
      <h6 class="text-muted text-uppercase small fw-semibold mb-3">
        <i class="fas fa-headset me-1"></i>Info supporto
      </h6>
      <div class="row g-3 mb-4">
        <div class="col-md-5">
          <label class="form-label">E-mail supporto</label>
          <input type="email" class="form-control" name="support_email"
            value="{{ entity.support_email|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-3">
          <label class="form-label">Telefono</label>
          <input type="text" class="form-control" name="support_phone"
            value="{{ entity.support_phone|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-4">
          <label class="form-label">Orari</label>
          <input type="text" class="form-control" name="support_hours"
            value="{{ entity.support_hours|default('') }}" placeholder="Lun-Ven 9:00-17:00"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-8">
          <label class="form-label">Indirizzo</label>
          <input type="text" class="form-control" name="support_location"
            value="{{ entity.support_location|default('') }}" {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
      </div>

      {% if is_superadmin %}
      <div class="d-flex justify-content-end border-top pt-3 mb-4">
        <button type="button" class="btn btn-primary" onclick="impSaveForm('form-generale', '/impostazioni/generale/save', this)">
          <i class="fas fa-save me-1"></i>Salva
        </button>
      </div>
      {% endif %}
    </form>

    {# ─── Immagini ─────────────────────────────────────────────────────────── #}
    {% if is_superadmin %}
    <hr>
    <h6 class="text-muted text-uppercase small fw-semibold mb-3">
      <i class="fas fa-image me-1"></i>Logo e Favicon
    </h6>
    <div class="row g-4">
      {# Logo / stemma #}
      <div class="col-md-6">
        <div class="card border">
          <div class="card-body text-center">
            <div class="mb-2">
              <img src="/img/stemma_ente.png" alt="Logo ente" style="max-height:80px;max-width:180px;object-fit:contain;"
                onerror="this.style.display='none'">
            </div>
            <p class="small text-muted mb-2">Logo / stemma ente (PNG, JPG, SVG)</p>
            <form id="form-logo" enctype="multipart/form-data" onsubmit="return false;">
              <div class="input-group">
                <input type="file" class="form-control form-control-sm" name="logo_file" id="logo-file"
                  accept=".png,.jpg,.jpeg,.svg">
                <button type="button" class="btn btn-sm btn-primary" onclick="uploadImage('form-logo', '/impostazioni/logo/upload', this)">
                  <i class="fas fa-upload me-1"></i>Carica
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
      {# Favicon #}
      <div class="col-md-6">
        <div class="card border">
          <div class="card-body text-center">
            <div class="mb-2">
              <img src="/img/favicon.png" alt="Favicon" style="max-height:48px;max-width:48px;object-fit:contain;"
                onerror="this.style.display='none'">
            </div>
            <p class="small text-muted mb-2">Favicon (PNG, ICO — 32×32 o 64×64)</p>
            <form id="form-favicon" enctype="multipart/form-data" onsubmit="return false;">
              <div class="input-group">
                <input type="file" class="form-control form-control-sm" name="favicon_file" id="favicon-file"
                  accept=".png,.ico">
                <button type="button" class="btn btn-sm btn-primary" onclick="uploadImage('form-favicon', '/impostazioni/favicon/upload', this)">
                  <i class="fas fa-upload me-1"></i>Carica
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
    {% endif %}
  </div>
</div>

<script>
async function uploadImage(formId, url, btn) {
  const form = document.getElementById(formId);
  const input = form.querySelector('input[type="file"]');
  if (!input.files.length) { impToast('Seleziona un file prima.', false); return; }
  btn.disabled = true;
  const orig = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
  try {
    const fd = new FormData(form);
    const res = await fetch(url, { method: 'POST', body: fd });
    const json = await res.json();
    impToast(json.message || (json.success ? 'Caricato.' : 'Errore.'), !!json.success);
    if (json.success) setTimeout(() => location.reload(), 1500);
  } catch(e) { impToast('Errore: ' + e.message, false); }
  finally { btn.disabled = false; btn.innerHTML = orig; }
}
</script>
