<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
    <h2 class="h5 mb-0"><i class="fas fa-receipt me-2 text-primary"></i>BizEvents</h2>
    <button class="btn btn-sm btn-outline-secondary" onclick="impTestBizEvents(this)">
      <i class="fas fa-wifi me-1"></i>Test connessione
    </button>
  </div>
  <div class="card-body">
    <p class="text-muted small mb-4">
      API pagoPA BizEvents per il recupero delle ricevute di pagamento dell'Ente Creditore.
    </p>
    <form id="form-api-bizevents" onsubmit="return false;">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label">BizEvents Host</label>
          <input type="url" class="form-control" name="biz_events_host"
            value="{{ pagopa.biz_events_host|default('') }}"
            placeholder="https://api.platform.pagopa.it/bizevents/service/v1"
            {{ not is_superadmin ? 'readonly' : '' }}>
          <div class="form-text">URL base dell'API BizEvents per il recupero ricevute EC.</div>
        </div>
        <div class="col-md-4">
          <label class="form-label">API Key</label>
          <div class="input-group">
            <input type="password" class="form-control font-monospace" name="biz_events_api_key" id="biz-key"
              value="{{ pagopa.biz_events_api_key|default('') }}" autocomplete="off"
              {{ not is_superadmin ? 'readonly' : '' }}>
            <button class="btn btn-outline-secondary" type="button" onclick="togglePwdBiz('biz-key', this)"><i class="fas fa-eye"></i></button>
          </div>
          <div class="form-text">Chiave di sottoscrizione BizEvents EC.</div>
        </div>
      </div>

      {% if is_superadmin %}
      <div class="d-flex justify-content-end border-top pt-3 mt-4">
        <button type="button" class="btn btn-primary"
          onclick="impSaveForm('form-api-bizevents', '/impostazioni/api-esterne/save', this)">
          <i class="fas fa-save me-1"></i>Salva
        </button>
      </div>
      {% endif %}
    </form>
  </div>
</div>

<script>
function togglePwdBiz(id, btn) {
  const el = document.getElementById(id);
  const show = el.type === 'password';
  el.type = show ? 'text' : 'password';
  btn.innerHTML = show ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
}
async function impTestBizEvents(btn) {
  btn.disabled = true;
  const orig = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Test…';
  try {
    const res = await fetch('/impostazioni/api-esterne/test-biz-events');
    const json = await res.json();
    impToast(json.message || (json.success ? 'OK.' : 'Fallito.'), !!json.success);
  } catch(e) { impToast('Errore: ' + e.message, false); }
  finally { btn.disabled = false; btn.innerHTML = orig; }
}
</script>
