<div class="card border-0 shadow-sm">
  <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
    <h2 class="h5 mb-0"><i class="fas fa-credit-card me-2 text-primary"></i>pagoPA Checkout</h2>
    <button class="btn btn-sm btn-outline-secondary" onclick="impTestApiEsterne('checkout', this)">
      <i class="fas fa-wifi me-1"></i>Test connessione
    </button>
  </div>
  <div class="card-body">
    <p class="text-muted small mb-4">Configurazione dell'API pagoPA Checkout (EC) per il gateway di pagamento online.</p>
    <form id="form-api-checkout" onsubmit="return false;">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label">Checkout EC Base URL</label>
          <input type="url" class="form-control" name="checkout_ec_base_url"
            value="{{ pagopa.checkout_ec_base_url|default('') }}"
            placeholder="https://api.platform.pagopa.it/checkout/ec/v1"
            {{ not is_superadmin ? 'readonly' : '' }}>
          <div class="form-text">URL base dell'API pagoPA Checkout per Enti Creditori.</div>
        </div>
        <div class="col-md-4">
          <label class="form-label">Subscription Key</label>
          <div class="input-group">
            <input type="password" class="form-control font-monospace" name="checkout_subscription_key" id="checkout-key"
              value="{{ pagopa.checkout_subscription_key|default('') }}" autocomplete="off"
              {{ not is_superadmin ? 'readonly' : '' }}>
            <button class="btn btn-outline-secondary" type="button" onclick="togglePwdApiCheckout('checkout-key', this)"><i class="fas fa-eye"></i></button>
          </div>
          <div class="form-text">Chiave di sottoscrizione per l'autenticazione API.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Nome ente (company name)</label>
          <input type="text" class="form-control" name="checkout_company_name"
            value="{{ pagopa.checkout_company_name|default('') }}"
            {{ not is_superadmin ? 'readonly' : '' }}>
          <div class="form-text">Nome visualizzato nel portale di pagamento pagoPA.</div>
        </div>
      </div>

      <hr class="my-4">
      <h6 class="text-muted text-uppercase small fw-semibold mb-3"><i class="fas fa-undo me-1"></i>URL di ritorno</h6>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Return URL — Pagamento completato</label>
          <input type="url" class="form-control" name="checkout_return_ok_url"
            value="{{ pagopa.checkout_return_ok_url|default('') }}"
            placeholder="https://…/pagamento/ok"
            {{ not is_superadmin ? 'readonly' : '' }}>
          <div class="form-text">Lasciare vuoto per usare la pagina interna del frontoffice.</div>
        </div>
        <div class="col-md-6">
          <label class="form-label">Return URL — Pagamento annullato</label>
          <input type="url" class="form-control" name="checkout_return_cancel_url"
            value="{{ pagopa.checkout_return_cancel_url|default('') }}"
            placeholder="https://…/pagamento/annullato"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
        <div class="col-md-6">
          <label class="form-label">Return URL — Errore</label>
          <input type="url" class="form-control" name="checkout_return_error_url"
            value="{{ pagopa.checkout_return_error_url|default('') }}"
            placeholder="https://…/pagamento/errore"
            {{ not is_superadmin ? 'readonly' : '' }}>
        </div>
      </div>

      {% if is_superadmin %}
      <div class="d-flex justify-content-end border-top pt-3 mt-4">
        <button type="button" class="btn btn-primary"
          onclick="impSaveForm('form-api-checkout', '/impostazioni/api-esterne/save', this)">
          <i class="fas fa-save me-1"></i>Salva
        </button>
      </div>
      {% endif %}
    </form>
  </div>
</div>

<script>
function togglePwdApiCheckout(id, btn) {
  const el = document.getElementById(id);
  const show = el.type === 'password';
  el.type = show ? 'text' : 'password';
  btn.innerHTML = show ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
}
async function impTestApiEsterne(api, btn) {
  btn.disabled = true;
  const orig = btn.innerHTML;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Test…';
  try {
    const res = await fetch('/impostazioni/api-esterne/test-' + api);
    const json = await res.json();
    impToast(json.message || (json.success ? 'OK.' : 'Fallito.'), !!json.success);
  } catch(e) { impToast('Errore: ' + e.message, false); }
  finally { btn.disabled = false; btn.innerHTML = orig; }
}
</script>
