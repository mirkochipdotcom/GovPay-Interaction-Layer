{% extends 'base.html.twig' %}

{% block title %}Profilo utente - GovPay{% endblock %}

{% block content %}
{%- set u = profile_user ?? current_user -%}
{%- set first = u.first_name|default('') -%}
{%- set last  = u.last_name|default('')  -%}
{%- set display_name = (first ~ (last != '' ? ' ' ~ last : ''))|trim -%}

<div class="d-flex align-items-center justify-content-between mb-3">
  <h1 class="h4 mb-0">
    <i class="fas fa-user-circle me-2 text-primary"></i>
    {{ display_name != '' ? display_name : u.email }}
  </h1>
  <a class="btn btn-outline-secondary btn-sm" href="/">&laquo; Torna alla home</a>
</div>

<div class="row g-3">
  {# ── Sidebar ─────────────────────────────────────────────── #}
  <div class="col-lg-3">
    <nav class="nav nav-pills flex-column" aria-label="Sezioni profilo">
      <a class="nav-link {{ tab == 'info' ? 'active' : '' }}" href="/profile?tab=info">
        <i class="fas fa-id-card me-2"></i>Dati personali
      </a>
      <a class="nav-link {{ tab == 'password' ? 'active' : '' }}" href="/profile?tab=password">
        <i class="fas fa-lock me-2"></i>Cambio password
      </a>
      <a class="nav-link {{ tab == 'templates' ? 'active' : '' }}" href="/profile?tab=templates">
        <i class="fas fa-file-invoice me-2"></i>Template assegnati
        {% if user_templates is defined and user_templates|length > 0 %}
          <span class="badge bg-secondary ms-1">{{ user_templates|length }}</span>
        {% endif %}
      </a>
    </nav>
  </div>

  {# ── Contenuto ───────────────────────────────────────────── #}
  <div class="col-lg-9">

    {% if error_profile %}
      <div class="alert alert-danger">{{ error_profile }}</div>
    {% endif %}

    {# ── TAB: Dati personali ──────────────────────────────── #}
    {% if tab == 'info' %}
      <h2 class="h5 mb-3">Dati personali</h2>
      <div class="card">
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4 text-muted fw-normal">Email</dt>
            <dd class="col-sm-8 font-monospace">{{ u.email|default('—') }}</dd>

            <dt class="col-sm-4 text-muted fw-normal">Nome</dt>
            <dd class="col-sm-8">{{ first != '' ? first : '—' }}</dd>

            <dt class="col-sm-4 text-muted fw-normal">Cognome</dt>
            <dd class="col-sm-8">{{ last != '' ? last|upper : '—' }}</dd>

            <dt class="col-sm-4 text-muted fw-normal">Ruolo</dt>
            <dd class="col-sm-8">
              {%- if u.role == 'superadmin' -%}
                <span class="badge bg-danger">superadmin</span>
              {%- elseif u.role == 'admin' -%}
                <span class="badge bg-warning text-dark">admin</span>
              {%- else -%}
                <span class="badge bg-secondary">user</span>
              {%- endif -%}
            </dd>

            <dt class="col-sm-4 text-muted fw-normal">Tipologia di default</dt>
            <dd class="col-sm-8">{{ user_default_tipologia_desc|default('—') }}</dd>
          </dl>
        </div>
        {% if current_user is defined and current_user.role in ['admin','superadmin'] %}
          <div class="card-footer text-end">
            <a class="btn btn-sm btn-outline-primary" href="/users/{{ u.id }}/edit">
              <i class="fas fa-pencil-alt me-1"></i>Modifica profilo
            </a>
          </div>
        {% endif %}
      </div>

    {# ── TAB: Cambio password ─────────────────────────────── #}
    {% elseif tab == 'password' %}
      <h2 class="h5 mb-3">Cambio password</h2>
      <div class="card">
        <div class="card-body">
          <form method="post" action="/profile/change-password" autocomplete="off">
            {# Honeypot anti-autofill #}
            <input type="text" name="fakeusernameremembered" autocomplete="username"
                   style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"
                   aria-hidden="true" tabindex="-1">

            <div class="mb-3">
              <label for="current_password" class="form-label">Password attuale</label>
              <input type="password" class="form-control" id="current_password"
                     name="current_password" required autocomplete="current-password"
                     autofocus>
            </div>
            <div class="mb-3">
              <label for="new_password" class="form-label">Nuova password</label>
              <input type="password" class="form-control" id="new_password"
                     name="new_password" required minlength="8" autocomplete="new-password">
              <div class="form-text">Almeno 8 caratteri.</div>
            </div>
            <div class="mb-4">
              <label for="new_password_confirm" class="form-label">Conferma nuova password</label>
              <input type="password" class="form-control" id="new_password_confirm"
                     name="new_password_confirm" required minlength="8" autocomplete="new-password">
            </div>
            <button type="submit" class="btn btn-primary">
              <i class="fas fa-save me-1"></i>Aggiorna password
            </button>
          </form>
        </div>
      </div>

    {# ── TAB: Template assegnati ──────────────────────────── #}
    {% elseif tab == 'templates' %}
      <h2 class="h5 mb-3">Template assegnati</h2>
      {% if user_templates is defined and user_templates|length > 0 %}
        <div class="row g-3">
          {% for tpl in user_templates %}
            <div class="col-md-6">
              <div class="card h-100">
                <div class="card-body">
                  <h3 class="h6 card-title mb-1">{{ tpl.titolo }}</h3>
                  <p class="text-muted small mb-2 font-monospace">{{ tpl.id_tipo_pendenza }}</p>
                  <dl class="row small mb-0">
                    <dt class="col-5 fw-normal text-muted">Causale</dt>
                    <dd class="col-7">{{ tpl.causale|default('—') }}</dd>
                    <dt class="col-5 fw-normal text-muted">Importo</dt>
                    <dd class="col-7">
                      {% if tpl.importo is not null and tpl.importo != '' %}
                        {{ tpl.importo|number_format(2, ',', '.') }} €
                      {% else %}
                        <span class="text-muted">—</span>
                      {% endif %}
                    </dd>
                  </dl>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="alert alert-info">
          <i class="fas fa-info-circle me-1"></i>
          {% if current_user is defined and current_user.role in ['admin', 'superadmin'] %}
            Nessun template è assegnato al tuo account. Puoi gestire i template e le loro assegnazioni dalla
            <a href="/configurazione?tab=templates">pagina di configurazione</a>.
          {% else %}
            Nessun template è assegnato al tuo account. Contatta un amministratore per richiedere l'accesso ai template di tuo interesse.
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

  </div>{# /col-lg-9 #}
</div>{# /row #}
{% endblock %}
