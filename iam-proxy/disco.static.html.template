<!DOCTYPE html>
<html lang="it">
<head>
  <meta http-equiv="content-type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Accedi | ${APP_ENTITY_NAME}</title>
  <meta name="description" content="Accedi ai servizi di ${APP_ENTITY_NAME} con SPID o CIE.">

  <!-- Bootstrap Italia CSS -->
  <link href="/static/css/bootstrap-italia.min.css" rel="stylesheet">
  <!-- ita-bayon CSS -->
  <link href="/static/css/ita.min.css" rel="stylesheet">
  <link type="text/css" rel="stylesheet" href="/static/spid/spid-sp-access-button.css">

  <script src="/static/js/jquery-3.7.0.min.js"></script>
  <script src="/static/js/bootstrap-italia.bundle.min.js"></script>

  <style>
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
    }

    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      background-color: #f8f9fa;
    }

    main {
      flex: 1;
    }

    header svg.icon {
      width: 32px;
      height: 32px;
    }

    footer {
      margin: 0;
      padding: 1rem 0;
      background-color: #0072CE;
      color: white;
      position: relative;
      width: 100%;
      height: auto;
    }

    .login-form-lg {
      background: white;
      border-radius: 6px;
      padding: 2rem;
      max-width: 760px;
    }

    .login-form-lg .nav-tabs {
      border-bottom: 2px solid #dee2e6;
    }

    .login-form-lg .nav-tabs .nav-link {
      color: #555;
      font-weight: 600;
      border: none;
      border-bottom: 3px solid transparent;
      border-radius: 0;
      padding: 0.75rem 1.5rem;
    }

    .login-form-lg .nav-tabs .nav-link.active {
      color: #0073e6;
      border-bottom-color: #0073e6;
      background: transparent;
    }

    .login-form-lg h2 {
      font-size: 1.35rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
      color: #1a1a1a;
    }

    /* Override SPID button list to show scrollable max height */
    ul#spid-idp-list-medium-root-get {
      max-height: 320px;
      overflow-y: auto;
    }

    /* Cap IDP logo size inside dropdown */
    #spid-idp-list-medium-root-get .spid-idp-button-link img {
      max-width: 130px;
      max-height: 36px;
      width: auto;
      height: auto;
      object-fit: contain;
    }

    @media (max-width: 576px) {
      .login-form-lg {
        padding: 1rem;
      }
    }

    .button-cie {
      background-color: #003D8F;
    }

    .mi-brand {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 0.75rem;
    }

    .mi-brand span {
      font-size: 0.72rem;
      font-weight: 700;
      color: #555;
      letter-spacing: 0.05em;
    }
  </style>
</head>
<body>

<!-- HEADER -->
<header class="it-header-wrapper">
  <div class="it-header-slim-wrapper bg-primary">
    <div class="container">
      <div class="it-header-slim-wrapper-content d-flex justify-content-between align-items-center">
        <a href="${APP_ENTITY_URL}" class="d-flex align-items-center text-white text-decoration-none" style="font-weight:600; font-size:1.1rem;">
          ${APP_ENTITY_NAME}
        </a>
      </div>
    </div>
  </div>
  <div style="background-color: #F2F7FC;">
    <div class="container py-3">
      <div class="d-flex align-items-center">
        <script>
          (function(){
            var src = "${APP_LOGO_SRC}";
            var base = "${FRONTOFFICE_PUBLIC_BASE_URL}";
            if(src && src !== "") {
              var fullSrc = src.startsWith('/') && base !== "" ? base + src : src;
              document.write('<img src="' + fullSrc + '" alt="${APP_ENTITY_NAME}" style="height:48px; margin-right:12px;" onerror="this.style.display=\'none\'">');
            } else {
              document.write('<img src="/static/svg/it-pa.svg" alt="Logo PA" style="height:48px; margin-right:12px;">');
            }
          })();
        </script>
        <h2 style="margin:0;">Accedi ai servizi di ${APP_ENTITY_NAME}</h2>
      </div>
    </div>
  </div>
</header>

<!-- SEZIONE LOGIN -->
<main class="container my-4">
  <div id="login-form" class="login-form-lg shadow mx-auto mt-3">
    <h2 class="h3">Accedi con identità digitale</h2>

    <ul class="nav nav-tabs flex-sm-row flex-sm-nowrap" id="myTab" role="tablist">
      <!-- SPID_BLOCK_START -->
      <li class="nav-item text-sm-center" role="presentation">
        <button class="nav-link h-100 px-4 active" id="tab-spid" data-bs-toggle="tab" data-bs-target="#panel-spid" type="button" role="tab" aria-controls="panel-spid" aria-selected="true">SPID</button>
      </li>
      <!-- SPID_BLOCK_END -->
      <!-- CIE_OIDC_BLOCK_START -->
      <li class="nav-item text-sm-center" role="presentation">
        <button class="nav-link h-100 px-4" id="tab-cie" data-bs-toggle="tab" data-bs-target="#panel-cie" type="button" role="tab" aria-controls="panel-cie" aria-selected="false" tabindex="-1">CIE</button>
      </li>
      <!-- CIE_OIDC_BLOCK_END -->
    </ul>

    <div class="tab-content" id="tab-content">

      <!-- SPID_BLOCK_START -->
      <div class="tab-pane fade show active" id="panel-spid" role="tabpanel" aria-labelledby="tab-spid">
        <h3 class="visually-hidden">Accedi con identità digitale SPID</h3>
        <p class="mt-3">SPID, il&nbsp;<strong>Sistema Pubblico di Identità Digitale</strong>&nbsp;è il sistema di accesso che consente di utilizzare, con un'identità digitale unica, i servizi online della Pubblica Amministrazione e dei privati accreditati. Se sei già in possesso di un'identità digitale, accedi con le credenziali del tuo gestore. Se non hai ancora un'identità digitale, richiedila ad uno dei gestori.</p>

        <div class="row align-items-center">
          <div class="col-12 col-md-6">
            <ul class="list-link px-1">
              <li class="mb-1">
                <a href="https://www.spid.gov.it/" target="_blank" rel="noopener noreferrer">
                  <span class="visually-hidden">Apre una nuova finestra</span>Maggiori informazioni su SPID</a>
              </li>
              <li class="mb-1">
                <a href="https://www.spid.gov.it/richiedi-spid" target="_blank" rel="noopener noreferrer">
                  <span class="visually-hidden">Apre una nuova finestra</span>Non hai SPID?</a>
              </li>
              <li class="mb-1">
                <a href="https://www.spid.gov.it/serve-aiuto" target="_blank" rel="noopener noreferrer">
                  <span class="visually-hidden">Apre una nuova finestra</span>Serve aiuto?</a>
              </li>
            </ul>
          </div>
          <div class="col-12 col-md-6 text-center">

            <!-- AGID - SPID IDP BUTTON MEDIUM "ENTRA CON SPID" * begin * -->
            <a href="#" class="italia-it-button italia-it-button-size-m button-spid" spid-idp-button="#spid-idp-button-medium-get" aria-haspopup="true" aria-expanded="false">
              <span class="italia-it-button-icon">
                <img src="/static/spid/spid-ico-circle-bb.svg" onerror="this.src='/static/spid/spid-ico-circle-bb.png'; this.onerror=null;" alt="">
              </span>
              <span class="italia-it-button-text">Entra con SPID</span>
            </a>
            <div id="spid-idp-button-medium-get" class="spid-idp-button spid-idp-button-tip spid-idp-button-relative">
              <ul id="spid-idp-list-medium-root-get" class="spid-idp-button-menu" aria-labelledby="spid-idp">
                <!-- SPID_DEMO_START -->
                <li class="spid-idp-button-link" data-idp="demo">
                  <a class="disco-idp-link" data-entity-id="https://demo.spid.gov.it">
                    <img src="/static/spid/spid-agid-logo-lb.png" alt="SPID Test (Demo)">
                  </a>
                </li>
                <!-- SPID_DEMO_END -->
                <!-- SPID_VALIDATOR_START -->
                <li class="spid-idp-button-link" data-idp="spidvalidator">
                  <a class="disco-idp-link" data-entity-id="https://validator.spid.gov.it">
                    <img src="/static/spid/spid-agid-logo-lb.png" alt="SPID Validator">
                  </a>
                </li>
                <!-- SPID_VALIDATOR_END -->
                <li class="spid-idp-button-link" data-idp="arubaid">
                  <a class="disco-idp-link" data-entity-id="https://loginspid.aruba.it">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-arubaid.svg" onerror="this.src='/static/spid/spid-idp-arubaid.png'; this.onerror=null;" alt="Aruba ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="infocertid">
                  <a class="disco-idp-link" data-entity-id="https://identity.infocert.it">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-infocertid.svg" onerror="this.src='/static/spid/spid-idp-infocertid.png'; this.onerror=null;" alt="Infocert ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="intesigroupspid">
                  <a class="disco-idp-link" data-entity-id="https://spid.intesa.it">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-intesaid.svg" onerror="this.src='/static/spid/spid-idp-intesaid.png'; this.onerror=null;" alt="Intesi Group S.p.A.">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="lepidaid">
                  <a class="disco-idp-link" data-entity-id="https://id.lepida.it/idp/shibboleth">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-lepidaid.svg" onerror="this.src='/static/spid/spid-idp-lepidaid.png'; this.onerror=null;" alt="Lepida ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="namirialid">
                  <a class="disco-idp-link" data-entity-id="https://idp.namirialtsp.com/idp">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-namirialid.svg" onerror="this.src='/static/spid/spid-idp-namirialid.png'; this.onerror=null;" alt="Namirial ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="posteid">
                  <a class="disco-idp-link" data-entity-id="https://posteid.poste.it">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-posteid.svg" onerror="this.src='/static/spid/spid-idp-posteid.png'; this.onerror=null;" alt="Poste ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="sielteid">
                  <a class="disco-idp-link" data-entity-id="https://identity.sieltecloud.it">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-sielteid.svg" onerror="this.src='/static/spid/spid-idp-sielteid.png'; this.onerror=null;" alt="Sielte ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="spiditalia">
                  <a class="disco-idp-link" data-entity-id="https://spid.register.it">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-spiditalia.svg" onerror="this.src='/static/spid/spid-idp-spiditalia.png'; this.onerror=null;" alt="SPIDItalia Register.it">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="timid">
                  <a class="disco-idp-link" data-entity-id="https://login.id.tim.it/affwebservices/public/saml2sso">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-timid.svg" onerror="this.src='/static/spid/spid-idp-timid.png'; this.onerror=null;" alt="Tim ID">
                  </a>
                </li>
                <li class="spid-idp-button-link" data-idp="teamsystemid">
                  <a class="disco-idp-link" data-entity-id="https://spid.teamsystem.com/idp">
                    <img style="box-sizing: content-box;" src="/static/spid/spid-idp-teamsystemid.svg" onerror="this.src='/static/spid/spid-idp-teamsystemid.png'; this.onerror=null;" alt="TeamSystem ID">
                  </a>
                </li>

              </ul>
            </div>
            <!-- AGID - SPID IDP BUTTON MEDIUM "ENTRA CON SPID" * end * -->

          </div>
          <img id="spid-agid" class="img-fluid mx-auto mt-3" src="/static/spid/spid-agid-logo-lb.png" alt="Logo SPID - AGID - Agenzia per l'Italia Digitale" style="max-height: 50px; width: auto;">
        </div>
      </div>
      <!-- SPID_BLOCK_END -->

      <!-- CIE_OIDC_BLOCK_START -->
      <div class="tab-pane fade" id="panel-cie" role="tabpanel" aria-labelledby="tab-cie">
        <h3 class="visually-hidden">Accedi con identità digitale CIE</h3>
        <p class="mt-3">La <strong>Carta d'Identità Elettronica</strong> (CIE) è il documento personale che attesta l'identità del cittadino. Dotata di microprocessore, oltre a comprovare l'identità personale, permette l'accesso ai servizi digitali della Pubblica Amministrazione.</p>

        <div class="row align-items-center">
          <div class="col-12 col-md-6">
            <a class="my-3 d-block" href="https://www.cartaidentita.interno.gov.it/" target="_blank" rel="noopener noreferrer">
              <span class="visually-hidden">Apre una nuova finestra</span>Maggiori informazioni
            </a>
          </div>
          <div class="col-12 col-md-6 text-center">
            <a class="d-inline-block my-3 disco-idp-link italia-it-button italia-it-button-size-m button-cie" data-entity-id="${CIE_OIDC_PROVIDER_URL}">
              <span class="italia-it-button-icon">
                <img src="/static/cie/cie_white.svg" alt="">
              </span>
              <span class="italia-it-button-text">Entra con CIE</span>
            </a>
          </div>
        </div>
        <div class="text-center">
          <div class="mi-brand">
            <img src="/static/cie/ministero@2x.png" alt="Ministero dell'Interno" style="height: 42px;">
          </div>
        </div>
      </div>
      <!-- CIE_OIDC_BLOCK_END -->

      <!-- IT_WALLET_BLOCK_START -->
      <div class="tab-pane fade" id="panel-itwallet" role="tabpanel">
        <p class="mt-3">Accedi con il tuo <strong>IT-Wallet</strong>.</p>
        <a class="disco-idp-link d-inline-block my-3" data-entity-id="wallet">
          <img src="/static/wallet-it/wallet_icon.svg" alt="IT Wallet" style="height:48px;">
        </a>
      </div>
      <!-- IT_WALLET_BLOCK_END -->

    </div><!-- /tab-content -->
  </div><!-- /login-form -->
</main>

<!-- FOOTER -->
<footer>
  <div class="container py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center w-100 gap-2">
      <div class="d-flex flex-wrap align-items-center">
        <a href="${SATOSA_UI_LEGAL_URL_IT}" class="text-white me-4 mb-2" target="_blank" rel="noopener">Note legali</a>
        <a href="${SATOSA_UI_PRIVACY_URL_IT}" class="text-white me-4 mb-2" target="_blank" rel="noopener">Privacy policy</a>
      </div>
      <div class="d-flex align-items-center gap-3">
        <a href="https://github.com/Comune-di-Montesilvano/GovPay-Interaction-Layer/releases/tag/${APP_VERSION}"
           target="_blank" rel="noopener noreferrer"
           class="text-white text-decoration-none" style="font-size:0.8rem; opacity:0.75;">
          IAMProxy@GovPayInteractionLayer ${APP_VERSION}
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  (function applyDiscoLinks() {
    const urlParams = new URLSearchParams(window.location.search);
    const servicePath = urlParams.get('return');
    if (!servicePath) {
      console.warn('[disco] Parametro ?return= mancante. La pagina è stata aperta direttamente.');
      return;
    }

    const sep = servicePath.includes('?') ? '&' : '?';

    document.querySelectorAll('.disco-idp-link').forEach((link) => {
      const entityId = link.getAttribute('data-entity-id');
      if (!entityId) return;
      link.setAttribute('href', servicePath + sep + 'entityID=' + encodeURIComponent(entityId));
    });
  })();
</script>
<script src="/static/spid/spid-sp-access-button.js"></script>
<script src="/static/spid/spid_button.js"></script>
</body>
</html>
