# ─────────────────────────────────────────────────────────────────────────────
# GovPay Interaction Layer — variabili di deploy
#
# In Portainer: Stacks → <stack> → Editor → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Versione immagini Docker (tag su GHCR).
# Esempi: latest, v1.0.0-alpha, v1.1.0
APP_VERSION=latest

# Porte esposte sull'host (de-commentare per sovrascrivere i default)
#BACKOFFICE_HTTP_PORT=8443
#FRONTOFFICE_HTTP_PORT=8444
#IAM_PROXY_HTTP_PORT=9445

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — credenziali generate automaticamente al primo avvio
# Il servizio db-secrets-init scrive ./runtime/.db-secrets.env con password
# casuali sicure. Non è necessario impostarle manualmente.
#
# Se vuoi usare credenziali personalizzate, puoi impostarle qui:
# (sovrascrivono quelle auto-generate solo se impostate esplicitamente)
# ─────────────────────────────────────────────────────────────────────────────
#DB_NAME=govpay
#DB_USER=govpay
#DB_USER_CITTADINI=govpay_cittadini

# ─────────────────────────────────────────────────────────────────────────────
# PROFILI COMPOSE — attiva IAM Proxy SPID/CIE (opzionale, default disabilitato)
# ─────────────────────────────────────────────────────────────────────────────
# COMPOSE_PROFILES=iam-proxy

# ─────────────────────────────────────────────────────────────────────────────
# VOLUME SPID (opzionale — default: govpay_spid_certs)
# Cambia solo se stai usando un volume SPID pre-esistente con nome diverso.
# ─────────────────────────────────────────────────────────────────────────────
# SPID_CERTS_DOCKER_VOLUME=govpay_spid_certs

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAZIONE SATOSA/SPID/CIE
# Generata automaticamente dal wizard → salvata in ./runtime/.iam-proxy.env
# Vedere .iam-proxy.env.example per la lista completa delle variabili.
# ─────────────────────────────────────────────────────────────────────────────
