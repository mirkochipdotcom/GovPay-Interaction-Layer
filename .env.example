# ─────────────────────────────────────────────────────────────────────────────
# GovPay Interaction Layer — variabili di deploy
#
# Queste sono le UNICHE variabili da impostare in Portainer (o nel file .env
# sull'host per deploy manuale). Tutto il resto è configurato dal wizard.
#
# In Portainer: Stacks → <stack> → Editor → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Versione immagini Docker (tag su GHCR).
# Esempi: latest, v1.0.0-alpha, v1.1.0
APP_VERSION=latest

# Porte esposte sull'host (protocollo HTTP/HTTPS dipende dalla configurazione Apache/Nginx)
BACKOFFICE_HTTP_PORT=8443
FRONTOFFICE_HTTP_PORT=8444
IAM_PROXY_HTTP_PORT=9445

# Nome del volume Docker per i certificati SPID (opzionale — default: govpay_spid_certs)
# Cambia solo se stai usando un volume SPID pre-esistente con nome diverso.
# SPID_CERTS_DOCKER_VOLUME=govpay_spid_certs

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — necessario solo se si bypassa il wizard (deploy manuale avanzato).
# In condizioni normali questi valori vengono scritti dal wizard in .env.bootstrap.
# ─────────────────────────────────────────────────────────────────────────────
# DB_ROOT_PASSWORD=changeme
# DB_NAME=govpay
# DB_USER=govpay
# DB_PASSWORD=changeme
# DB_USER_CITTADINI=govpay_cittadini
# DB_PASSWORD_CITTADINI=changeme_cittadini

# ─────────────────────────────────────────────────────────────────────────────
# PROFILI COMPOSE — attiva IAM Proxy SPID/CIE (opzionale)
# ─────────────────────────────────────────────────────────────────────────────
# COMPOSE_PROFILES=iam-proxy

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAZIONE SATOSA/SPID/CIE
# Vedere .iam-proxy.env.example — generato automaticamente dal wizard/impostazioni
# ─────────────────────────────────────────────────────────────────────────────
