# ─────────────────────────────────────────────────────────────────────────────
# GovPay Interaction Layer — variabili di deploy
#
# In Portainer: Stacks → <stack> → Editor → Environment variables
# In locale: copia in .env e personalizza i valori
# ─────────────────────────────────────────────────────────────────────────────

# Versione immagini Docker (tag su GHCR).
# Esempi: latest, v1.0.0-alpha, v1.1.0
APP_VERSION=latest

# ─────────────────────────────────────────────────────────────────────────────
# APACHE / SSL
# ─────────────────────────────────────────────────────────────────────────────
APACHE_SERVER_NAME=localhost
# SSL=on  abilita HTTPS su Apache (richiede certificati in ./ssl/)
# SSL=off disabilita SSL (utile dietro reverse proxy)
SSL=off

# Porte esposte sull'host
BACKOFFICE_HTTP_PORT=8443
FRONTOFFICE_HTTP_PORT=8444
#IAM_PROXY_HTTP_PORT=9445

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — OBBLIGATORIO impostare tutte le variabili prima del primo avvio
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=govpay
DB_ROOT_PASSWORD=cambia_con_password_sicura

# Utente backoffice (lettura/scrittura)
BACKOFFICE_DB_USER=govpay
BACKOFFICE_DB_PASSWORD=cambia_con_password_sicura

# Utente frontoffice (sola lettura)
FRONTOFFICE_DB_USER=govpay_cittadini
FRONTOFFICE_DB_PASSWORD=cambia_con_password_sicura

# ─────────────────────────────────────────────────────────────────────────────
# MASTER TOKEN — Bearer token per la comunicazione backoffice→master container
# Genera con: openssl rand -hex 24
# ─────────────────────────────────────────────────────────────────────────────
MASTER_TOKEN=cambia_con_token_casuale_sicuro

# ─────────────────────────────────────────────────────────────────────────────
# CHIAVE DI CIFRATURA — usata per cifrare segreti nel DB (app IO, ecc.)
# Deve essere esattamente 32 caratteri. Genera con: openssl rand -hex 16
# ─────────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=cambia_con_32_caratteri_esatti_ok

# ─────────────────────────────────────────────────────────────────────────────
# PROFILI COMPOSE — attiva IAM Proxy SPID/CIE (opzionale, default disabilitato)
# ─────────────────────────────────────────────────────────────────────────────
# COMPOSE_PROFILES=iam-proxy

# ─────────────────────────────────────────────────────────────────────────────
# VOLUME SPID (opzionale — default: govpay_spid_certs)
# ─────────────────────────────────────────────────────────────────────────────
# SPID_CERTS_DOCKER_VOLUME=govpay_spid_certs

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAZIONE SATOSA/SPID/CIE
# Vedere .iam-proxy.env.example per la lista completa delle variabili.
# ─────────────────────────────────────────────────────────────────────────────
