# ─────────────────────────────────────────────────────────────────────────────
# GovPay Interaction Layer — variabili di deploy
#
# In Portainer: Stacks → <stack> → Editor → Environment variables
# In locale: copia in .env e personalizza i valori
# ─────────────────────────────────────────────────────────────────────────────

# Versione immagini Docker (tag su GHCR).
# Esempi: latest, v1.0.0-alpha, v1.1.0
APP_VERSION=latest

# ─────────────────────────────────────────────────────────────────────────────
# APACHE / SSL
# ─────────────────────────────────────────────────────────────────────────────
APACHE_SERVER_NAME=localhost
# SSL=on  abilita HTTPS su Apache (richiede certificati nel volume gil_ssl_certs)
# SSL=off disabilita SSL (utile dietro reverse proxy)
SSL=off

# Porte esposte sull'host
BACKOFFICE_HTTP_PORT=8443
FRONTOFFICE_HTTP_PORT=8444
#IAM_PROXY_HTTP_PORT=9445

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — OBBLIGATORIO impostare tutte le variabili prima del primo avvio
# ─────────────────────────────────────────────────────────────────────────────
DB_NAME=govpay
DB_ROOT_PASSWORD=cambia_con_password_sicura

# Utente backoffice (lettura/scrittura)
BACKOFFICE_DB_USER=govpay
BACKOFFICE_DB_PASSWORD=cambia_con_password_sicura

# Utente frontoffice (sola lettura)
FRONTOFFICE_DB_USER=govpay_cittadini
FRONTOFFICE_DB_PASSWORD=cambia_con_password_sicura

# ─────────────────────────────────────────────────────────────────────────────
# CHIAVE DI CIFRATURA — usata per cifrare segreti nel DB (app IO, ecc.)
# Deve essere esattamente 32 caratteri. Genera con: openssl rand -hex 16
# ─────────────────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=cambia_con_32_caratteri_esatti_ok

# ─────────────────────────────────────────────────────────────────────────────
# PORTAINER API — opzionale
# Abilita la gestione container (restart/start/stop) dall'interfaccia backoffice.
# Se non configurato, quelle funzioni mostrano un banner informativo.
# ─────────────────────────────────────────────────────────────────────────────
#PORTAINER_URL=http://portainer:9000
#PORTAINER_API_TOKEN=ptr_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#PORTAINER_ENDPOINT_ID=1

# ─────────────────────────────────────────────────────────────────────────────
# PROFILI COMPOSE — attiva IAM Proxy SPID/CIE (opzionale, default disabilitato)
# ─────────────────────────────────────────────────────────────────────────────
# COMPOSE_PROFILES=iam-proxy

# ─────────────────────────────────────────────────────────────────────────────
# VOLUME SPID (opzionale — default: govpay_spid_certs)
# ─────────────────────────────────────────────────────────────────────────────
# SPID_CERTS_DOCKER_VOLUME=govpay_spid_certs

# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAZIONE IAM PROXY (SATOSA / SPID / CIE)
# Necessario solo se COMPOSE_PROFILES=iam-proxy.
# In Portainer impostare direttamente come variabili d'ambiente dello stack.
# Vedere .iam-proxy.env.example per la descrizione completa di ogni variabile.
# ─────────────────────────────────────────────────────────────────────────────

# --- Generale ---
#IAM_PROXY_DEBUG=false
#FRONTOFFICE_AUTH_PROXY_TYPE=iam-proxy-saml2
#IAM_PROXY_HOSTNAME=satosa-nginx
#IAM_PROXY_HTTP_PORT=9445
#SATOSA_HOSTNAME=satosa-nginx

# --- URL pubbliche SATOSA ---
#SATOSA_BASE=https://satosa-nginx.example.org
#SATOSA_BASE_STATIC=https://satosa-nginx.example.org/static
#SATOSA_DISCO_SRV=https://satosa-nginx.example.org/static/disco.html
#SATOSA_UNKNOW_ERROR_REDIRECT_PAGE=https://frontoffice.example.org
#SATOSA_CANCEL_REDIRECT_URL=https://satosa-nginx.example.org/errors/cancel.html

# --- Chiavi SATOSA (CAMBIARE IN PRODUZIONE — stringhe random >= 32 chars) ---
#SATOSA_SALT=CHANGE_THIS_RANDOM_STRING_32_CHARS_LONG
#SATOSA_STATE_ENCRYPTION_KEY=CHANGE_THIS_RANDOM_STRING_32_CHARS_LONG
#SATOSA_ENCRYPTION_KEY=CHANGE_THIS_RANDOM_STRING_32_CHARS_LONG
#SATOSA_USER_ID_HASH_SALT=CHANGE_THIS_RANDOM_STRING_32_CHARS_LONG

# --- Organizzazione e contatti (metadata SPID) ---
#SATOSA_ORGANIZATION_DISPLAY_NAME_IT="Comune di Esempio"
#SATOSA_ORGANIZATION_NAME_IT="Comune di Esempio"
#SATOSA_ORGANIZATION_URL_IT=https://comune.esempio.it
#SATOSA_CONTACT_PERSON_GIVEN_NAME="Supporto"
#SATOSA_CONTACT_PERSON_EMAIL_ADDRESS=supporto@comune.esempio.it
#SATOSA_CONTACT_PERSON_TELEPHONE_NUMBER="+39XXXXXXXXXX"
#SATOSA_CONTACT_PERSON_FISCALCODE=XXXXXXXXXXX000W
#SATOSA_CONTACT_PERSON_IPA_CODE=c_x000
#SATOSA_ORGANIZATION_IDENTIFIER=PA:IT-c_x000

# --- Generatori certificati SPID ---
#SPID_CERT_ENTITY_ID=https://frontoffice.example.org/saml/sp
#SPID_CERT_COMMON_NAME="Comune di Esempio"
#SPID_CERT_ORG_NAME="Comune di Esempio"
#SPID_CERT_ORG_ID=PA:IT-c_x000
#SPID_CERT_LOCALITY_NAME=Roma

# --- CIE OIDC ---
#CIE_OIDC_CLIENT_ID=https://satosa-nginx.example.org/CieOidcRp
#CIE_OIDC_CLIENT_NAME="Nome Organizzazione"
#CIE_OIDC_REDIRECT_URI=https://satosa-nginx.example.org/CieOidcRp/oidc/callback
#CIE_OIDC_JWKS_URI=https://satosa-nginx.example.org/CieOidcRp/openid_relying_party/jwks.json
#CIE_OIDC_CONTACT_EMAIL=pec@comune.esempio.legalmail.it

# --- MongoDB (backend SATOSA) ---
#MONGODB_USERNAME=satosa_user
#MONGODB_PASSWORD=satosa_password
